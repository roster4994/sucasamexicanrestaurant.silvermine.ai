---
const leftNavItems = [
  { href: '/order', label: 'Order Online' },
];

const rightNavItems = [
  { href: '/menu', label: 'Menu' },
  { href: '/catering', label: 'Catering' },
];

const currentPath = Astro.url.pathname;
---

<header class="header">
  <nav class="nav-bar" aria-label="Main navigation">
    <div class="nav-container container">
      <!-- Left nav items -->
      <ul class="nav-menu nav-left" role="menubar">
        {leftNavItems.map((item) => (
          <li role="none">
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
              role="menuitem"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Centered Logo -->
      <a href="/" class="logo" aria-label="Su Casa Mexican Restaurant - Home">
        <img src="https://i.postimg.cc/Nj2jKLLq/logo.png" alt="Su Casa Mexican Restaurant" class="logo-image" />
      </a>

      <!-- Right nav items -->
      <ul class="nav-menu nav-right" role="menubar">
        {rightNavItems.map((item) => (
          <li role="none">
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
              role="menuitem"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>

      <!-- Mobile menu toggle -->
      <button
        class="mobile-menu-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-nav-menu"
      >
        <span class="hamburger"></span>
      </button>

      <!-- Mobile menu -->
      <ul id="mobile-nav-menu" class="mobile-menu" role="menubar">
        {[...leftNavItems, ...rightNavItems].map((item) => (
          <li role="none">
            <a
              href={item.href}
              class:list={['nav-link', { active: currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href)) }]}
              role="menuitem"
            >
              {item.label}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </nav>
</header>

<style>
  .header {
    position: fixed;
    top: 50px;
    left: 0;
    right: 0;
    z-index: 100;
    transition: top 0.3s ease;
  }

  .header.scrolled {
    top: 35px;
  }

  .nav-bar {
    background: rgba(209, 97, 93, 0.95);
    backdrop-filter: blur(10px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.3);
    padding: 0.5rem 0;
    margin: 0 auto;
    max-width: calc(100% - 40px);
    border-radius: 50px;
    transition: all 0.3s ease;
  }

  .header.scrolled .nav-bar {
    padding: 0.3rem 0;
    max-width: calc(100% - 60px);
    background: rgba(209, 97, 93, 0.98);
  }

  .nav-container {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0 var(--spacing-md);
    max-width: 1400px;
    position: relative;
    margin: 0 auto;
  }

  /* Logo - Centered and overlapping */
  .logo {
    display: block;
    text-decoration: none;
    margin: 0 3rem;
    position: relative;
    z-index: 10;
    transition: transform 0.3s ease;
  }

  .logo:hover {
    transform: scale(1.05);
  }

  .logo-image {
    height: 140px;
    width: auto;
    display: block;
    margin-top: -45px;
    margin-bottom: -45px;
    object-fit: contain;
    filter: drop-shadow(0 4px 8px rgba(0, 0, 0, 0.3));
    transition: all 0.3s ease;
  }

  .header.scrolled .logo-image {
    height: 110px;
    margin-top: -35px;
    margin-bottom: -35px;
  }

  /* Navigation menus */
  .nav-menu {
    display: flex;
    align-items: center;
    gap: 1rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .nav-left {
    flex: 1;
    justify-content: flex-end;
  }

  .nav-right {
    flex: 1;
    justify-content: flex-start;
  }

  .nav-link {
    display: block;
    padding: 0.75rem 1.5rem;
    color: #ffffff;
    text-decoration: none;
    font-weight: 500;
    font-size: 1.15rem;
    text-transform: uppercase;
    letter-spacing: 1px;
    border-radius: 25px;
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    position: relative;
    white-space: nowrap;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
  }

  .nav-link:hover {
    color: #ffffff;
    background-color: rgba(0, 0, 0, 0.2);
    transform: scale(1.1);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .nav-link.active {
    color: var(--color-tertiary, #f2ba65);
    background-color: rgba(0, 0, 0, 0.25);
  }

  .header.scrolled .nav-link {
    font-size: 1rem;
    padding: 0.5rem 1.25rem;
  }

  /* Mobile menu toggle */
  .mobile-menu-toggle {
    display: none;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 101;
    position: absolute;
    right: 1.5rem;
  }

  .hamburger {
    display: block;
    width: 28px;
    height: 3px;
    background: #ffffff;
    border-radius: 2px;
    position: relative;
    transition: all var(--transition-fast);
  }

  .hamburger::before,
  .hamburger::after {
    content: '';
    position: absolute;
    left: 0;
    width: 100%;
    height: 3px;
    background: #ffffff;
    border-radius: 2px;
    transition: all var(--transition-fast);
  }

  .hamburger::before {
    top: -8px;
  }

  .hamburger::after {
    bottom: -8px;
  }

  .mobile-menu-toggle[aria-expanded="true"] .hamburger {
    background: transparent;
  }

  .mobile-menu-toggle[aria-expanded="true"] .hamburger::before {
    top: 0;
    transform: rotate(45deg);
  }

  .mobile-menu-toggle[aria-expanded="true"] .hamburger::after {
    bottom: 0;
    transform: rotate(-45deg);
  }

  /* Mobile menu (hidden by default) */
  .mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    right: -100%;
    width: 280px;
    height: 100vh;
    flex-direction: column;
    align-items: stretch;
    gap: 0;
    padding: 5rem 1.5rem 2rem;
    background: rgba(209, 97, 93, 0.98);
    backdrop-filter: blur(10px);
    box-shadow: -5px 0 20px rgba(0, 0, 0, 0.3);
    transition: right var(--transition-normal);
    overflow-y: auto;
    list-style: none;
    margin: 0;
  }

  .mobile-menu.open {
    right: 0;
  }

  .mobile-menu .nav-link {
    padding: 1rem;
    font-size: 1.2rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 0;
  }

  .mobile-menu .nav-link:hover {
    transform: translateX(10px);
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .header {
      top: 35px;
    }

    .header.scrolled {
      top: 25px;
    }

    .nav-bar {
      max-width: calc(100% - 30px);
      border-radius: 30px;
    }

    .nav-container {
      justify-content: center;
    }

    .mobile-menu-toggle {
      display: block;
    }

    .nav-left,
    .nav-right {
      display: none;
    }

    .mobile-menu {
      display: flex;
    }

    .logo {
      margin: 0 auto;
    }

    .logo-image {
      height: 120px;
      width: auto;
      margin-top: -40px;
      margin-bottom: -40px;
    }

    .header.scrolled .logo-image {
      height: 90px;
      margin-top: -30px;
      margin-bottom: -30px;
    }
  }
</style>

<script>
  const header = document.querySelector('.header');
  const toggle = document.querySelector('.mobile-menu-toggle');
  const menu = document.querySelector('.mobile-menu');

  // Scroll detection for shrinking header
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.scrollY;

    if (currentScroll > 50) {
      header?.classList.add('scrolled');
    } else {
      header?.classList.remove('scrolled');
    }

    lastScroll = currentScroll;
  });

  toggle?.addEventListener('click', () => {
    const isExpanded = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!isExpanded));
    menu?.classList.toggle('open');
    document.body.style.overflow = isExpanded ? '' : 'hidden';
  });

  // Close menu when clicking a link
  menu?.querySelectorAll('.nav-link').forEach(link => {
    link.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    });
  });

  // Close menu on escape key
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && menu?.classList.contains('open')) {
      toggle?.setAttribute('aria-expanded', 'false');
      menu?.classList.remove('open');
      document.body.style.overflow = '';
    }
  });
</script>
