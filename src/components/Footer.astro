---
const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: '/menu', label: 'Menu' },
  { href: '/drinks', label: 'Drinks' },
  { href: '/specials', label: 'Specials' },
  { href: '/catering', label: 'Catering' },
  { href: '/order', label: 'Order Online' },
  { href: '/contact', label: 'Contact Us' },
];

const hours = [
  { days: 'Monday - Thursday', time: '11:00 AM - 8:00 PM' },
  { days: 'Friday - Saturday', time: '11:00 AM - 9:00 PM' },
  { days: 'Sunday', time: 'Closed' },
];
---

<footer class="footer">
  <div class="footer-pattern"></div>
  <div class="container">
    <div class="footer-grid">
      <!-- Brand Column -->
      <div class="footer-brand">
        <a href="/" class="footer-logo">
          <span class="logo-icon">🌮</span>
          <span class="logo-text">
            <span class="logo-name">Su Casa</span>
            <span class="logo-tagline">Mexican Restaurant</span>
          </span>
        </a>
        <p class="brand-description">
          Family owned since 1978. Where comfort food meets vibrant tradition in the heart of Midvale, UT.
        </p>
        <div class="social-links">
          <a href="https://facebook.com/sucasamexicanrestaurant" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a href="https://instagram.com/sucasamexicanrestaurant" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
          </a>
          <a href="https://google.com/maps/place/Su+Casa+Mexican+Restaurant" target="_blank" rel="noopener noreferrer" aria-label="Google">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M12 0C5.383 0 0 5.383 0 12s5.383 12 12 12 12-5.383 12-12S18.617 0 12 0zm-1.5 18.75h-3v-3h3v3zm0-4.5h-3v-7.5h3v7.5zm6 4.5h-3v-7.5h3v7.5zm0-9h-3v-3h3v3z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="footer-links">
        <h3>Quick Links</h3>
        <ul>
          {quickLinks.map((link) => (
            <li><a href={link.href}>{link.label}</a></li>
          ))}
        </ul>
      </div>

      <!-- Hours -->
      <div class="footer-hours">
        <h3>Hours of Operation</h3>
        <ul class="hours-list">
          {hours.map((item) => (
            <li>
              <span class="days">{item.days}</span>
              <span class="time">{item.time}</span>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-contact">
        <h3>Contact Us</h3>
        <address>
          <p>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            6878 State Street<br>Midvale, UT 84047
          </p>
          <p>
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+18012551042">(801) 255-1042</a>
          </p>
        </address>
        <div class="delivery-partners">
          <span>Order on:</span>
          <div class="partner-links">
            <a href="https://www.doordash.com/store/su-casa-mexican-restaurant-midvale-922561/" target="_blank" rel="noopener noreferrer">DoorDash</a>
            <a href="https://www.grubhub.com/restaurant/su-casa-mexican-restaurant-6878-state-st-midvale/1472764" target="_blank" rel="noopener noreferrer">GrubHub</a>
            <a href="https://www.ubereats.com/store/su-casa-mexican-restaurant/midvale" target="_blank" rel="noopener noreferrer">Uber Eats</a>
          </div>
        </div>
      </div>
    </div>

    <div class="footer-bottom">
      <p>&copy; {currentYear} Su Casa Mexican Restaurant. All rights reserved.</p>
      <p class="made-with">Made with ❤️ in Midvale, Utah</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: linear-gradient(135deg, var(--bg-dark) 0%, #3D2518 100%);
    color: var(--color-cream);
    padding: var(--spacing-xl) 0 var(--spacing-md);
    position: relative;
    overflow: hidden;
  }

  .footer-pattern {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 8px;
    background: linear-gradient(90deg, var(--color-primary), var(--color-secondary), var(--color-tertiary), var(--color-green), var(--color-primary));
  }

  .footer-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-lg);
  }

  .footer-logo {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    text-decoration: none;
    color: inherit;
    margin-bottom: var(--spacing-sm);
  }

  .footer-logo .logo-icon {
    font-size: 2.5rem;
  }

  .footer-logo .logo-name {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-tertiary);
    display: block;
    line-height: 1.1;
  }

  .footer-logo .logo-tagline {
    font-size: 0.7rem;
    color: var(--color-sand);
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .brand-description {
    color: var(--color-sand);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: var(--spacing-sm);
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background: rgba(255, 255, 255, 0.1);
    border-radius: 50%;
    color: var(--color-cream);
    transition: all var(--transition-fast);
  }

  .social-links a:hover {
    background: var(--color-tertiary);
    color: var(--bg-dark);
    transform: translateY(-3px);
  }

  .footer h3 {
    color: var(--color-tertiary);
    font-size: 1.1rem;
    margin-bottom: var(--spacing-sm);
    font-family: var(--font-heading);
  }

  .footer-links ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-links li {
    margin-bottom: 0.5rem;
  }

  .footer-links a {
    color: var(--color-sand);
    text-decoration: none;
    transition: color var(--transition-fast);
    font-size: 0.95rem;
  }

  .footer-links a:hover {
    color: var(--color-tertiary);
  }

  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hours-list li {
    display: flex;
    flex-direction: column;
    margin-bottom: 0.75rem;
    padding-bottom: 0.75rem;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .hours-list li:last-child {
    border-bottom: none;
    margin-bottom: 0;
    padding-bottom: 0;
  }

  .hours-list .days {
    color: var(--color-cream);
    font-weight: 500;
    font-size: 0.9rem;
  }

  .hours-list .time {
    color: var(--color-sand);
    font-size: 0.9rem;
  }

  .footer-contact address {
    font-style: normal;
  }

  .footer-contact p {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    color: var(--color-sand);
    margin-bottom: 0.75rem;
    font-size: 0.95rem;
  }

  .footer-contact svg {
    flex-shrink: 0;
    color: var(--color-tertiary);
    margin-top: 2px;
  }

  .footer-contact a {
    color: var(--color-sand);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-contact a:hover {
    color: var(--color-tertiary);
  }

  .delivery-partners {
    margin-top: var(--spacing-sm);
    padding-top: var(--spacing-sm);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .delivery-partners span {
    display: block;
    font-size: 0.85rem;
    color: var(--color-sand);
    margin-bottom: 0.5rem;
  }

  .partner-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .partner-links a {
    display: inline-block;
    padding: 0.35rem 0.75rem;
    background: rgba(255, 255, 255, 0.1);
    border-radius: var(--radius-sm);
    color: var(--color-cream);
    font-size: 0.85rem;
    text-decoration: none;
    transition: all var(--transition-fast);
  }

  .partner-links a:hover {
    background: var(--color-primary);
    color: white;
  }

  .footer-bottom {
    text-align: center;
    padding-top: var(--spacing-md);
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .footer-bottom p {
    color: var(--color-sand);
    font-size: 0.9rem;
    margin: 0;
  }

  .made-with {
    margin-top: 0.5rem !important;
    font-size: 0.85rem !important;
  }

  @media (max-width: 768px) {
    .footer {
      padding: var(--spacing-lg) 0 var(--spacing-sm);
    }

    .footer-grid {
      gap: var(--spacing-md);
    }

    .footer-brand {
      text-align: center;
    }

    .social-links {
      justify-content: center;
    }
  }
</style>
