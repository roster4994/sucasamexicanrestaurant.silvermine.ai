---
import Layout from '../layouts/Layout.astro';
import Breadcrumb from '../components/Breadcrumb.astro';

const hours = [
  { days: "Monday", time: "11:00 AM - 8:00 PM" },
  { days: "Tuesday", time: "11:00 AM - 8:00 PM" },
  { days: "Wednesday", time: "11:00 AM - 8:00 PM" },
  { days: "Thursday", time: "11:00 AM - 8:00 PM" },
  { days: "Friday", time: "11:00 AM - 9:00 PM" },
  { days: "Saturday", time: "11:00 AM - 9:00 PM" },
  { days: "Sunday", time: "Closed" }
];

const siteUrl = 'https://sucasamexicanrestaurant.com';

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": `${siteUrl}/contact`,
  "name": "Contact Su Casa Mexican Restaurant | Midvale, UT | (801) 255-1042",
  "description": "Contact Su Casa Mexican Restaurant in Midvale, UT. Call (801) 255-1042, visit us at 6878 S State Street, or order online. Mon–Thu 11–8, Fri–Sat 11–9.",
  "url": `${siteUrl}/contact`,
  "isPartOf": { "@id": `${siteUrl}/#website` }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    },
    {
      "@type": "ListItem",
      "position": 2,
      "name": "Contact",
      "item": `${siteUrl}/contact`
    }
  ]
};
---

<Layout
  title="Contact Su Casa Mexican Restaurant | Midvale, UT | (801) 255-1042"
  description="Contact Su Casa Mexican Restaurant in Midvale, UT. Call (801) 255-1042, visit us at 6878 S State Street, or order online. Mon–Thu 11–8, Fri–Sat 11–9."
>
<Fragment slot="head">
  <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Fragment>
  <!-- Page Header -->
  <section class="page-header">
    <div class="container">
      <h1>Contact Su Casa Mexican Restaurant in Midvale, UT</h1>
      <p>We'd love to hear from you — stop by, call, or order online!</p>
    </div>
  </section>
  <Breadcrumb current="Contact" />

  <div class="contact-content">
    <div class="container">
      <!-- Contact Grid -->
      <div class="contact-grid">
        <!-- Location Info -->
        <div class="contact-info">
          <div class="info-card">
            <h2>Find Us</h2>
            <address>
              <div class="info-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
                <div>
                  <strong>Address</strong>
                  <p>6878 S State Street<br>Midvale, UT 84047</p>
                </div>
              </div>
              <div class="info-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
                </svg>
                <div>
                  <strong>Phone</strong>
                  <p><a href="tel:+18012551042">(801) 255-1042</a></p>
                </div>
              </div>
              <div class="info-item">
                <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="4" width="20" height="16" rx="2"/>
                  <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
                </svg>
                <div>
                  <strong>Email</strong>
                  <p><a href="mailto:scscmo@gmail.com">scscmo@gmail.com</a></p>
                </div>
              </div>
            </address>
          </div>

          <div class="hours-card">
            <h2>Hours of Operation</h2>
            <ul class="hours-list">
              {hours.map((item) => (
                <li class:list={[{ closed: item.time === "Closed" }]}>
                  <span class="day">{item.days}</span>
                  <span class="time">{item.time}</span>
                </li>
              ))}
            </ul>
          </div>

          <div class="social-card">
            <h2>Follow Us</h2>
            <p>Stay connected for updates, specials, and more!</p>
            <div class="social-links">
              <a href="https://facebook.com/sucasamexicanrestaurant" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="social-btn facebook">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
                </svg>
                Facebook
              </a>
              <a href="https://www.instagram.com/sucasamidvale/" target="_blank" rel="noopener noreferrer" aria-label="Follow Su Casa on Instagram" class="social-btn instagram">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
                  <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
                  <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
                </svg>
                Instagram
              </a>
              <a href="https://www.yelp.com/biz/su-casa-mexican-restaurant-midvale" target="_blank" rel="noopener noreferrer" aria-label="Su Casa on Yelp" class="social-btn yelp">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg>
                Yelp
              </a>
              <a href="https://google.com/maps/place/Su+Casa+Mexican+Restaurant" target="_blank" rel="noopener noreferrer" aria-label="Google" class="social-btn google">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                </svg>
                Google
              </a>
            </div>
          </div>
        </div>

        <!-- Map -->
        <div class="map-section">
          <div class="map-container">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3026.5!2d-111.8926335!3d40.6264145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x875289b066322b6f%3A0x1b428f9fb0f21030!2sSu%20Casa%20Mexican%20Restaurant!5e0!3m2!1sen!2sus!4v1706489600000!5m2!1sen!2sus"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Su Casa Mexican Restaurant location in Midvale, UT"
            ></iframe>
            <div class="map-overlay">
              <a href="https://www.google.com/maps/place/Su+Casa+Mexican+Restaurant/@40.6264145,-111.8904448,17z/" target="_blank" rel="noopener noreferrer" class="btn btn-primary">
                Get Directions
              </a>
            </div>
          </div>
          <div class="directions-info">
            <h3>Getting Here</h3>
            <ul>
              <li><strong>From I-15:</strong> Take exit 301 for 7200 S, head west, turn north on State St</li>
              <li><strong>Parking:</strong> Free parking available in our lot</li>
              <li><strong>Public Transit:</strong> UTA bus routes available on State Street</li>
            </ul>
          </div>
        </div>
      </div>

      <!-- Quick Actions -->
      <section class="quick-actions">
        <h2>Quick Links</h2>
        <div class="actions-grid">
          <a href="/menu" class="action-card">
            <span class="action-icon">&#x1F4CB;</span>
            <h3>View Menu</h3>
            <p>Explore our full menu</p>
          </a>
          <a href="/order" class="action-card">
            <span class="action-icon">&#x1F697;</span>
            <h3>Order Online</h3>
            <p>Delivery or pickup</p>
          </a>
          <a href="/catering" class="action-card">
            <span class="action-icon">&#x1F389;</span>
            <h3>Catering</h3>
            <p>For your events</p>
          </a>
          <a href="/specials" class="action-card">
            <span class="action-icon">&#x2B50;</span>
            <h3>Specials</h3>
            <p>Daily deals</p>
          </a>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--bg-dark) 0%, #415f84 100%);
    padding: var(--spacing-xl) 0;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  .page-header::before {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 20% 80%, rgba(209, 97, 93, 0.2) 0%, transparent 50%),
      radial-gradient(circle at 80% 20%, rgba(242, 186, 101, 0.15) 0%, transparent 50%);
  }

  .page-header h1 {
    color: var(--color-tertiary);
    position: relative;
    margin-bottom: var(--spacing-xs);
  }

  .page-header p {
    color: var(--color-sand);
    font-size: 1.2rem;
    position: relative;
    margin: 0;
  }

  .contact-content {
    padding: var(--spacing-lg) 0 var(--spacing-xl);
  }

  /* Contact Grid */
  .contact-grid {
    display: grid;
    grid-template-columns: 400px 1fr;
    gap: var(--spacing-lg);
    margin-bottom: var(--spacing-xl);
  }

  /* Info Cards */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .info-card,
  .hours-card,
  .social-card {
    background: white;
    padding: var(--spacing-md);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .info-card h2,
  .hours-card h2,
  .social-card h2 {
    color: var(--color-brown-dark);
    font-size: 1.25rem;
    margin: 0 0 var(--spacing-sm);
    padding-bottom: var(--spacing-xs);
    border-bottom: 2px solid var(--color-cream);
  }

  .info-card address {
    font-style: normal;
  }

  .info-item {
    display: flex;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
  }

  .info-item:last-child {
    margin-bottom: 0;
  }

  .info-item svg {
    color: var(--color-primary);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .info-item strong {
    display: block;
    color: var(--color-brown-dark);
    margin-bottom: 0.25rem;
  }

  .info-item p {
    color: var(--color-text);
    margin: 0;
  }

  .info-item a {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Hours */
  .hours-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .hours-list li {
    display: flex;
    justify-content: space-between;
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-cream);
  }

  .hours-list li:last-child {
    border-bottom: none;
  }

  .hours-list .day {
    color: var(--color-text);
    font-weight: 500;
  }

  .hours-list .time {
    color: var(--color-text-light);
  }

  .hours-list li.closed .time {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* Social */
  .social-card p {
    color: var(--color-text-light);
    margin-bottom: var(--spacing-sm);
  }

  .social-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .social-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.5rem 1rem;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    color: white;
    transition: all var(--transition-fast);
  }

  .social-btn.facebook {
    background: #415f84;
  }

  .social-btn.instagram {
    background: linear-gradient(45deg, #d1615d, #66596e, #415f84);
  }

  .social-btn.yelp {
    background: #d32323;
  }

  .social-btn.google {
    background: #74bab1;
  }

  .social-btn:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
    color: white;
  }

  /* Map */
  .map-section {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-md);
  }

  .map-container {
    position: relative;
    height: 400px;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-md);
    background: var(--color-cream);
  }

  .map-container iframe {
    position: absolute;
    inset: 0;
  }

  .map-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--spacing-sm);
    background: linear-gradient(transparent, rgba(0, 0, 0, 0.8));
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .directions-info {
    background: white;
    padding: var(--spacing-md);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
  }

  .directions-info h3 {
    color: var(--color-brown-dark);
    margin: 0 0 var(--spacing-sm);
  }

  .directions-info ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .directions-info li {
    padding: 0.5rem 0;
    color: var(--color-text);
    font-size: 0.95rem;
    border-bottom: 1px solid var(--color-cream);
  }

  .directions-info li:last-child {
    border-bottom: none;
  }

  /* Quick Actions */
  .quick-actions h2 {
    text-align: center;
    color: var(--color-brown-dark);
    margin-bottom: var(--spacing-md);
  }

  .actions-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md);
  }

  .action-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding: var(--spacing-md);
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: all var(--transition-normal);
    border-top: 3px solid var(--color-tertiary);
  }

  .action-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .action-icon {
    font-size: 2.5rem;
    margin-bottom: var(--spacing-xs);
  }

  .action-card h3 {
    color: var(--color-brown-dark);
    margin: 0 0 0.25rem;
    font-size: 1.1rem;
  }

  .action-card p {
    color: var(--color-text-light);
    margin: 0;
    font-size: 0.9rem;
  }

  @media (max-width: 900px) {
    .contact-grid {
      grid-template-columns: 1fr;
    }

    .map-container {
      height: 300px;
    }
  }
</style>
