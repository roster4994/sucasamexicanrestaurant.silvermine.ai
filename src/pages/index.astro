<script>
  // Scroll-triggered animations
  document.addEventListener('DOMContentLoaded', () => {
    const animatedElements = document.querySelectorAll('.slide-in-image, .fade-in-element');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, {
      threshold: 0.2,
      rootMargin: '0px 0px -50px 0px'
    });

    animatedElements.forEach(el => observer.observe(el));

    // Add subtle parallax effect on mouse move for the image
    const aboutSection = document.querySelector('.about');
    const aboutImage = document.querySelector('.about-image-container');

    if (aboutSection && aboutImage) {
      aboutSection.addEventListener('mousemove', (e) => {
        const rect = aboutSection.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;

        if (aboutImage.classList.contains('visible')) {
          aboutImage.style.transform = `translateX(${x * 10}px) translateY(${y * 10}px)`;
        }
      });

      aboutSection.addEventListener('mouseleave', () => {
        if (aboutImage.classList.contains('visible')) {
          aboutImage.style.transform = 'translateX(0) translateY(0)';
        }
      });
    }

    // Mobile tap interactions for collage items
    const collageItems = document.querySelectorAll('.collage-item');

    collageItems.forEach(item => {
      item.addEventListener('click', (e) => {
        // Check if the click was on the order button - if so, let it proceed normally
        if (e.target.classList.contains('order-btn')) {
          return;
        }

        // Check if we're on a touch device or small screen
        const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        const isSmallScreen = window.innerWidth <= 768;

        if (isTouchDevice || isSmallScreen) {
          // If already active, close it
          if (item.classList.contains('active')) {
            item.classList.remove('active');
          } else {
            // Close all other active items
            collageItems.forEach(other => other.classList.remove('active'));
            // Open this one
            item.classList.add('active');
          }
        }
      });
    });

    // Close active collage item when clicking outside
    document.addEventListener('click', (e) => {
      if (!e.target.closest('.collage-item')) {
        collageItems.forEach(item => item.classList.remove('active'));
      }
    });

    // Mobile tap for map "Get Directions" overlay
    const mapLink = document.querySelector('.map-link');
    if (mapLink) {
      mapLink.addEventListener('click', (e) => {
        const isTouchDevice = 'ontouchstart' in window || navigator.maxTouchPoints > 0;
        const isSmallScreen = window.innerWidth <= 768;

        if (isTouchDevice || isSmallScreen) {
          // If not already showing overlay, show it first
          if (!mapLink.classList.contains('active')) {
            e.preventDefault();
            mapLink.classList.add('active');
          }
          // If already active, let the click proceed to the link
        }
      });

      // Close map overlay when clicking outside
      document.addEventListener('click', (e) => {
        if (!e.target.closest('.map-link')) {
          mapLink.classList.remove('active');
        }
      });
    }
  });
</script>
