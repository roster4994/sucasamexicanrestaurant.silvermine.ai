---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import collageMexicanDinner from '../assets/images/collage/mexican-dinner.jpg';
import collageNachoSupreme from '../assets/images/collage/nacho-supreme.jpg';
import collageQuesoDip from '../assets/images/collage/queso-dip.jpg';
import mediaComboPlate from '../assets/images/media/combo-plate-10.jpg';
import mediaChileRelleno from '../assets/images/media/chili-relleno.jpg';
import mediaChileVerde from '../assets/images/media/chile-verde-dinner.jpg';

const testimonials = [
  {
    quote: "Delicious Mexican food with an authentic feel... the queso is a tasty twist on an old favorite.",
    author: "Dave S."
  },
  {
    quote: "Always an excellent experience at Su Casa. Their salsa is the best! The staff are always friendly.",
    author: "Victoria G."
  },
  {
    quote: "I've been going to Su Casa for decades and have never had a bad meal.",
    author: "Brett E."
  }
];



const siteUrl = 'https://sucasamexicanrestaurant.com';

const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Su Casa Mexican Restaurant",
  "image": "https://sucasamexicanrestaurant.com/_astro/logo.ChkLogVw_XKnHR.webp",
  "url": "https://sucasamexicanrestaurant.com",
  "telephone": "+1-801-255-1042",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6878 S State Street",
    "addressLocality": "Midvale",
    "addressRegion": "UT",
    "postalCode": "84047",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6264145,
    "longitude": -111.8904448
  },
  "servesCuisine": ["Mexican", "Tex-Mex", "Latin American"],
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday"],
      "opens": "11:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Friday","Saturday"],
      "opens": "11:00",
      "closes": "21:00"
    }
  ],
  "menu": "https://sucasamexicanrestaurant.com/menu",
  "hasMenu": {
    "@type": "Menu",
    "url": "https://sucasamexicanrestaurant.com/menu"
  },
  "acceptsReservations": "No",
  "foundingDate": "1978",
  "description": "Family-owned since 1978, Su Casa serves authentic Mexican food in Midvale, UT. Dine in, order online, or cater your next event.",
  "sameAs": [
    "https://www.instagram.com/sucasamidvale/",
    "https://www.yelp.com/biz/su-casa-mexican-restaurant-midvale",
    "https://www.doordash.com/store/su-casa-mexican-restaurant-midvale-922561/",
    "https://www.grubhub.com/restaurant/su-casa-mexican-restaurant-6878-state-st-midvale/1472764"
  ],
  "potentialAction": {
    "@type": "OrderAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/"
    },
    "deliveryMethod": ["http://purl.org/goodrelations/v1#DeliveryModePickUp"]
  }
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": "Su Casa Mexican Restaurant",
  "url": siteUrl,
  "publisher": { "@id": `${siteUrl}/#restaurant` }
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/`,
  "name": "Su Casa Mexican Restaurant | Authentic Mexican Food in Midvale, UT",
  "description": "Family owned since 1978, Su Casa Mexican Restaurant in Midvale, UT offers authentic Mexican cuisine in a cozy, festive atmosphere.",
  "url": siteUrl,
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#restaurant` }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    }
  ]
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What are Su Casa's hours of operation?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We're open Monday through Thursday from 11 AM to 8 PM, and Friday through Saturday from 11 AM to 9 PM. We're closed on Sundays."
      }
    },
    {
      "@type": "Question",
      "name": "Does Su Casa offer catering?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes! We cater events of all sizes across Salt Lake County — from birthday parties and corporate lunches to wedding receptions. Call (801) 255-1042 to discuss your event."
      }
    },
    {
      "@type": "Question",
      "name": "Can I order Su Casa food for delivery?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes. Order directly through our website for pickup, or get delivery through DoorDash, GrubHub, and Uber Eats."
      }
    },
    {
      "@type": "Question",
      "name": "Where is Su Casa located?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "6878 S State Street, Midvale, UT 84047 — on the State Street corridor in the heart of Midvale, serving the greater Salt Lake Valley."
      }
    },
    {
      "@type": "Question",
      "name": "How long has Su Casa been open?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Su Casa Mexican Restaurant has been family-owned and operated since 1978 — over 45 years of serving authentic Mexican food to the Midvale community."
      }
    },
    {
      "@type": "Question",
      "name": "Does Su Casa take reservations?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "We operate on a first-come, first-served basis. For large parties or private events, contact us at (801) 255-1042."
      }
    }
  ]
};

const faqs = [
  {
    question: "What are Su Casa's hours of operation?",
    answer: "We're open Monday through Thursday from 11 AM to 8 PM, and Friday through Saturday from 11 AM to 9 PM. We're closed on Sundays."
  },
  {
    question: "Does Su Casa offer catering?",
    answer: 'Yes! We cater events of all sizes across Salt Lake County — from birthday parties and corporate lunches to wedding receptions. Visit our <a href="/catering">catering page</a> or call us at <a href="tel:+18012551042">(801) 255-1042</a> to discuss your event.'
  },
  {
    question: "Can I order Su Casa food for delivery?",
    answer: 'Absolutely. You can <a href="/order">order directly</a> through our website for pickup, or get delivery through DoorDash, GrubHub, and Uber Eats.'
  },
  {
    question: "Where is Su Casa located?",
    answer: 'We\'re at 6878 S State Street, Midvale, UT 84047 — right on the State Street corridor in the heart of Midvale, serving the greater Salt Lake Valley. <a href="https://www.google.com/maps/place/Su+Casa+Mexican+Restaurant/@40.6264145,-111.8904448,17z/" target="_blank" rel="noopener noreferrer">Get directions</a>.'
  },
  {
    question: "How long has Su Casa been open?",
    answer: "Su Casa Mexican Restaurant has been family-owned and operated since 1978 — over 45 years of serving authentic Mexican food to the Midvale community."
  },
  {
    question: "Does Su Casa take reservations?",
    answer: 'We operate on a first-come, first-served basis and don\'t take reservations. For large parties or private events, please contact us at <a href="tel:+18012551042">(801) 255-1042</a> or visit our <a href="/catering">catering page</a>.'
  }
];
---

<Layout title="Authentic Mexican Restaurant in Midvale, UT | Su Casa — Since 1978" description="Family-owned since 1978, Su Casa serves authentic Mexican food in Midvale, UT. Enjoy enchiladas, fajitas, chile verde & more. Dine in, order online, or cater your next event.">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
  </Fragment>
  <!-- Hero Section -->
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline preload="metadata" poster="/media/hero-poster.jpg">
      <source src="/media/banner-video.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-pattern"></div>
    <div class="hero-content container">
      <h1>Authentic Mexican Restaurant in Midvale, UT — Family Owned Since 1978</h1>
      <div class="hero-ctas">
        <a href="/order" class="btn btn-primary">ORDER ONLINE</a>
        <a href="/catering" class="btn btn-outline">Inquire for Catering</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll to explore</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2 class="section-title fade-in-element">Our Story: Serving Midvale Homemade Mexican Food for Over 45 Years</h2>
          <p class="about-text fade-in-element" style="--delay: 0.1s">
            Founded by longtime restaurateur Fred Osterloh, Su Casa Mexican Restaurant is rooted in a love for bold flavors, homemade recipes, and doing things the right way. Years before opening Su Casa, Fred spent time traveling, tasting, and carefully refining recipes—laying the groundwork for the menu long before the doors ever opened.
          </p>
          <p class="about-text fade-in-element" style="--delay: 0.2s">
            After opening several beloved restaurants, including Frederico's, Fred's Burger Chalet, and his first Mexican restaurant, El Sol, Fred brought everything he learned together when he opened Su Casa in June of 1978.
          </p>
          <p class="about-text fade-in-element" style="--delay: 0.3s">
            After Fred's retirement in 1999, the restaurant was passed down to his youngest son, Michael Osterloh, and today continues under the care of Denice Osterloh, carrying on the same comforting food and welcoming atmosphere Midvale has loved for generations.
          </p>
          <a href="/about" class="about-link fade-in-element" style="--delay: 0.4s">Learn more about our history &rarr;</a>
        </div>
        <div class="about-visual">
          <div class="about-image-container slide-in-image">
            <img src="https://i.postimg.cc/Qd38H8mx/IMG-5925.avif" alt="Su Casa Mexican Restaurant exterior in Midvale, UT — family owned since 1978" class="about-image" width="1200" height="900" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Collage Section -->
  <section class="photo-collage">
    <div class="collage-grid">
        <div class="collage-item collage-item-1">
          <Image src={collageMexicanDinner} alt="Authentic Mexican dinner plate with rice, beans, and enchiladas at Su Casa Restaurant in Midvale, UT" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Mexican Dinner</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Enchiladas Online</a>
          </div>
        </div>
        <div class="collage-item collage-item-2">
          <img src="https://i.postimg.cc/fyGxtdST/Copy-of-special-burrito-copy.jpg" alt="Su Casa's special burrito with homemade salsa and fresh guacamole" width="800" height="534" loading="lazy" decoding="async" />
          <div class="collage-overlay">
            <span class="dish-name">Special Burrito</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Burritos Online</a>
          </div>
        </div>
        <div class="collage-item collage-item-3">
          <Image src={collageNachoSupreme} alt="Loaded nachos with beans, cheese, jalapeños, and sour cream at Su Casa" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Nacho Supreme</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Nachos Online</a>
          </div>
        </div>
        <div class="collage-item collage-item-4">
          <Image src={collageQuesoDip} alt="Fresh queso dip appetizer at Su Casa Mexican Restaurant Midvale UT" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Queso Dip</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Queso Dip</a>
          </div>
        </div>
        <div class="collage-item collage-item-5">
          <img src="https://i.postimg.cc/RVwKn077/Copy-of-7-copy.jpg" alt="#7 Burrito verde, bean tostada & cheese enchilada" width="800" height="534" loading="lazy" decoding="async" />
          <div class="collage-overlay">
            <span class="dish-name">#7 Burrito verde, bean tostada & cheese enchilada</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-6">
          <img src="https://i.postimg.cc/Y0jvKXt6/Copy-of-baja-dinner-(2).jpg" alt="Baja fish tacos with cabbage slaw and secret Baja sauce — Su Casa Midvale" width="800" height="534" loading="lazy" decoding="async" />
          <div class="collage-overlay">
            <span class="dish-name">Baja Fish Tacos</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Baja Fish Tacos</a>
          </div>
        </div>
        <div class="collage-item collage-item-7">
          <Image src={mediaComboPlate} alt="Bean tostada combo plate with rice and beans at Su Casa Midvale" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">#10 Bean Tostada</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Mexican Food Online</a>
          </div>
        </div>
        <div class="collage-item collage-item-8">
          <Image src={mediaChileRelleno} alt="Homemade chile relleno stuffed with cheese at Su Casa Mexican Restaurant" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Chile Relleno</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Chile Relleno</a>
          </div>
        </div>
        <div class="collage-item collage-item-9">
          <Image src={mediaChileVerde} alt="Homemade chile verde dinner served with flour tortillas at Su Casa Midvale" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Chile Verde Dinner</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
    </div>
    <div class="collage-cta">
      <a href="/menu" class="collage-menu-link">View Full Menu &rarr;</a>
    </div>
  </section>

  <!-- Menu Highlights / Keyword Content Section -->
  <section class="menu-highlights section">
    <div class="container">
      <h2 class="section-title">Authentic Mexican Favorites Made Fresh Daily in Midvale</h2>
      <div class="highlights-content">
        <p>
          For over 45 years, Su Casa has been the heart of Mexican dining on State Street in Midvale, Utah. As the South Valley's most beloved family-owned Mexican restaurant since 1978, we take pride in preparing every dish from scratch using authentic recipes perfected over decades. From our signature chile verde — slow-simmered with tender pork and roasted green chiles — to sizzling fajitas loaded with peppers and onions, every plate that leaves our kitchen carries the flavors of tradition.
        </p>
        <p>
          Our menu features the authentic Mexican food that Salt Lake County has come to love: hand-rolled enchiladas smothered in our homemade red or green sauce, oversized burritos stuffed with seasoned meats and fresh toppings, crispy Baja fish tacos with cabbage slaw and our secret Baja sauce, and golden chile rellenos filled with melting cheese. Start your meal with our famous queso dip or a plate of loaded nachos topped with beans, jalape&ntilde;os, and sour cream — perfect for sharing with family and friends.
        </p>
        <p>
          Whether you're joining us for a weekday lunch on State Street, ordering delivery across Midvale and the greater Salt Lake Valley, or letting us cater your next celebration, you'll taste the difference that nearly five decades of family tradition makes at Su Casa Mexican Restaurant. <a href="/menu">Explore our full menu</a> and discover why generations of families keep coming back.
        </p>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials section">
    <div class="container">
      <h2 class="section-title">What Our Guests Say About Su Casa</h2>
      <p class="section-subtitle">Join thousands of satisfied customers who call Su Casa their favorite</p>
      <div class="testimonials-grid grid grid-3">
        {testimonials.map((testimonial) => (
          <div class="testimonial-card card">
            <div class="quote-icon">"</div>
            <blockquote>
              <p>{testimonial.quote}</p>
              <footer>— {testimonial.author}</footer>
            </blockquote>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-map-container">
          <a href="https://www.google.com/maps/place/Su+Casa+Mexican+Restaurant/@40.6264145,-111.8904448,17z/data=!3m1!4b1!4m6!3m5!1s0x875289b066322b6f:0x1b428f9fb0f21030!8m2!3d40.6264145!4d-111.8904448!16s%2Fg%2F1tffvdvd?entry=ttu" target="_blank" rel="noopener" class="map-link">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3026.5!2d-111.8926335!3d40.6264145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x875289b066322b6f%3A0x1b428f9fb0f21030!2sSu%20Casa%20Mexican%20Restaurant!5e0!3m2!1sen!2sus!4v1706489600000!5m2!1sen!2sus"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Su Casa Mexican Restaurant location on Google Maps">
            </iframe>
            <div class="map-overlay">
              <span class="directions-text">Get Directions</span>
            </div>
          </a>
          <a href="https://share.google/5fDBzyKZfgpYTgiUf" target="_blank" rel="noopener" class="gbp-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 92.3 132.3" width="20" height="28" class="maps-icon">
              <path fill="#1a73e8" d="M60.2 2.2C55.8.8 51 0 46.1 0 32 0 19.3 6.4 10.8 16.5l21.8 18.3L60.2 2.2z"/>
              <path fill="#ea4335" d="M10.8 16.5C4.1 24.5 0 34.9 0 46.1c0 8.7 1.7 15.7 4.6 22l28-33.3-21.8-18.3z"/>
              <path fill="#4285f4" d="M46.2 28.5c9.8 0 17.7 7.9 17.7 17.7 0 4.3-1.6 8.3-4.2 11.4 0 0 13.9-16.6 27.5-32.7-5.6-10.8-15.3-19-27-22.7L32.6 34.8c3.3-3.8 8.1-6.3 13.6-6.3z"/>
              <path fill="#fbbc04" d="M46.2 63.8c-9.8 0-17.7-7.9-17.7-17.7 0-4.3 1.5-8.3 4.1-11.3l-28 33.3c4.8 10.6 12.8 19.2 21 29.9l34.1-40.5c-3.3 3.9-8.1 6.3-13.5 6.3z"/>
              <path fill="#34a853" d="M59.1 109.2c15.4-24.1 33.3-35 33.3-63 0-7.7-1.9-14.9-5.2-21.3L25.6 98c2.6 3.4 5.3 7.3 7.9 11.3 9.4 14.5 6.8 23.1 12.8 23.1s3.4-8.7 12.8-23.2z"/>
            </svg>
            <span>Find us on Google</span>
          </a>
        </div>
        <div class="cta-content">
          <h2>Order Authentic Mexican Food Online or Dine In</h2>
          <p>Visit us today or order online for pickup and delivery</p>
          <div class="cta-buttons">
            <a href="/order" class="btn btn-secondary">Order Online</a>
            <a href="/catering" class="btn btn-secondary">Catering</a>
            <a href="/contact" class="btn btn-secondary">Contact Us</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="faq section">
    <div class="container">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq, i) => (
          <details class="faq-item" open={i === 0}>
            <summary class="faq-question">
              <span>{faq.question}</span>
              <svg class="faq-icon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </summary>
            <div class="faq-answer" set:html={faq.answer} />
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Newsletter Signup Section -->
  <section class="newsletter section">
    <div class="container">
      <div class="newsletter-content">
        <h2>Stay Updated with Su Casa Mexican Restaurant</h2>
        <a href="https://l.spoton.com/mmAbKB" target="_blank" rel="noopener noreferrer" class="btn newsletter-btn">Sign up for our newsletter</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 115vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    overflow: hidden;
    margin-top: -140px;
    padding-top: 140px;
  }

  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .hero-pattern {
    display: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--spacing-md);
