---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    quote: "Delicious Mexican food with an authentic feel... the queso is a tasty twist on an old favorite.",
    author: "Dave S."
  },
  {
    quote: "Always an excellent experience at Su Casa. Their salsa is the best! The staff are always friendly.",
    author: "Victoria G."
  },
  {
    quote: "I've been going to Su Casa for decades and have never had a bad meal.",
    author: "Brett E."
  },
  {
    quote: "The best enchiladas in town! My family has been coming here for years.",
    author: "Maria L."
  },
  {
    quote: "Authentic flavors that remind me of my grandmother's cooking. Truly special!",
    author: "Carlos R."
  }
];

const features = [
  {
    icon: "🎉",
    title: "Catering Services",
    description: "Did you know we do catering? Whatever your occasion, however big or small, we have the perfect options to choose from. Cater your birthday party, holiday party, corporate events, wedding festivities and more!",
    link: "/catering",
    linkText: "Learn More"
  },
  {
    icon: "🎊",
    title: "Spice Up Your Celebrations",
    description: "Host a memorable party with our flavorful menu options. From intimate gatherings to grand celebrations, we'll make your event unforgettable.",
    link: "/contact",
    linkText: "Contact Us"
  },
  {
    icon: "🚗",
    title: "Order Online",
    description: "Can't dine in? No problem! Order your favorite dishes for pickup or delivery through our partner services.",
    link: "/order",
    linkText: "Order Now"
  }
];

const menuCategories = [
  { icon: "🌯", name: "Burritos", description: "Stuffed with your choice of fillings and smothered in our signature sauces", popular: "California Burrito" },
  { icon: "🌮", name: "Tacos", description: "Crispy or soft shell, filled with perfectly seasoned meats", popular: "Street Tacos" },
  { icon: "🫔", name: "Enchiladas", description: "Hand-rolled and covered in authentic red or green sauce", popular: "Enchiladas Suizas" },
  { icon: "🍳", name: "Fajitas", description: "Sizzling platters of steak or chicken with peppers and onions", popular: "Combo Fajitas" }
];
---

<Layout title="Home">
  <!-- Floating Order Button -->
  <a href="/order" class="floating-order-btn" id="floatingOrderBtn" aria-label="Order Online">
    <span class="floating-icon">🌮</span>
    <span class="floating-text">Order Now</span>
  </a>

  <!-- Hero Section -->
  <section class="hero" id="hero">
    <div class="hero-overlay"></div>
    <div class="hero-pattern" id="heroPattern"></div>
    <div class="hero-content container">
      <span class="hero-badge animate-fade-in">Family Owned Since 1978</span>
      <h1 class="animate-fade-in" style="animation-delay: 0.2s">Welcome to Su Casa Mexican Restaurant</h1>
      <p class="hero-subtitle" id="typewriter"></p>
      <div class="hero-ctas animate-fade-in" style="animation-delay: 0.6s">
        <a href="/order" class="btn btn-primary btn-pulse">Order Online</a>
        <a href="/catering" class="btn btn-outline">Inquire for Catering</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll to explore</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section bg-pattern">
    <div class="container">
      <div class="about-grid">
        <div class="about-content scroll-reveal" data-direction="left">
          <h2 class="section-title">Our Story</h2>
          <p class="about-text">
            Family owned since 1978, our cozy and festive atmosphere has been home to delicious, Mexican cuisine that warms the soul. Every meal here feels like home.
          </p>
          <p class="about-text">
            For over four decades, we've been serving the Midvale community with authentic recipes passed down through generations. Our vibrant murals and warm hospitality reflect the heart and soul of Mexican culture.
          </p>
          <a href="/menu" class="btn btn-secondary">Explore Our Menu</a>
        </div>
        <div class="about-visual scroll-reveal" data-direction="right">
          <div class="about-image-placeholder interactive-image" id="foodShowcase">
            <div class="placeholder-content">
              <span class="placeholder-icon" id="rotatingEmoji">🌮</span>
              <span class="placeholder-text">Authentic Mexican Cuisine</span>
            </div>
            <div class="image-overlay">
              <span>Click to explore our dishes</span>
            </div>
          </div>
          <div class="about-stats" id="statsSection">
            <div class="stat">
              <span class="stat-number" data-count="45" data-suffix="+">0</span>
              <span class="stat-label">Years Serving</span>
            </div>
            <div class="stat">
              <span class="stat-number" data-count="100" data-suffix="+">0</span>
              <span class="stat-label">Menu Items</span>
            </div>
            <div class="stat">
              <span class="stat-number" data-count="50000" data-suffix="+">0</span>
              <span class="stat-label">Happy Customers</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Features Section -->
  <section class="features section">
    <div class="container">
      <h2 class="section-title scroll-reveal">What We Offer</h2>
      <p class="section-subtitle scroll-reveal">More than just great food - we're here for all your celebrations</p>
      <div class="features-grid grid grid-3">
        {features.map((feature, index) => (
          <div class="feature-card card scroll-reveal" data-direction="up" style={`animation-delay: ${index * 0.15}s`}>
            <div class="feature-icon animate-bounce-hover">{feature.icon}</div>
            <h3>{feature.title}</h3>
            <p>{feature.description}</p>
            <a href={feature.link} class="feature-link">{feature.linkText} <span class="arrow">→</span></a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Menu Preview Section -->
  <section class="menu-preview section bg-dark">
    <div class="container">
      <h2 class="section-title scroll-reveal">Taste Our Favorites</h2>
      <p class="section-subtitle scroll-reveal">From sizzling fajitas to handcrafted enchiladas</p>
      <div class="menu-preview-grid">
        {menuCategories.map((category, index) => (
          <div class="menu-category scroll-reveal flip-card" data-direction="up" style={`animation-delay: ${index * 0.1}s`}>
            <div class="flip-card-inner">
              <div class="flip-card-front">
                <span class="category-icon">{category.icon}</span>
                <h3>{category.name}</h3>
                <p>{category.description}</p>
              </div>
              <div class="flip-card-back">
                <span class="category-icon">{category.icon}</span>
                <h3>Try Our</h3>
                <p class="popular-item">{category.popular}</p>
                <a href="/menu" class="btn btn-sm btn-secondary">View Menu</a>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-lg scroll-reveal">
        <a href="/menu" class="btn btn-secondary">View Full Menu</a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials section bg-cream">
    <div class="container">
      <h2 class="section-title scroll-reveal">What Our Guests Say</h2>
      <p class="section-subtitle scroll-reveal">Join thousands of satisfied customers who call Su Casa their favorite</p>

      <div class="testimonial-carousel" id="testimonialCarousel">
        <button class="carousel-btn carousel-prev" id="prevBtn" aria-label="Previous testimonial">
          <span>&#8249;</span>
        </button>

        <div class="carousel-track-container">
          <div class="carousel-track" id="carouselTrack">
            {testimonials.map((testimonial, index) => (
              <div class="testimonial-slide" data-index={index}>
                <div class="testimonial-card card">
                  <div class="quote-icon">"</div>
                  <blockquote>
                    <p>{testimonial.quote}</p>
                    <footer>— {testimonial.author}</footer>
                  </blockquote>
                </div>
              </div>
            ))}
          </div>
        </div>

        <button class="carousel-btn carousel-next" id="nextBtn" aria-label="Next testimonial">
          <span>&#8250;</span>
        </button>
      </div>

      <div class="carousel-dots" id="carouselDots">
        {testimonials.map((_, index) => (
          <button class={`carousel-dot ${index === 0 ? 'active' : ''}`} data-index={index} aria-label={`Go to testimonial ${index + 1}`}></button>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section scroll-reveal">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Experience Su Casa?</h2>
        <p>Visit us today or order online for pickup and delivery</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary">Find Our Location</a>
          <a href="/order" class="btn btn-secondary">Order Online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* ===== ANIMATIONS ===== */
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes fadeInLeft {
    from { opacity: 0; transform: translateX(-50px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeInRight {
    from { opacity: 0; transform: translateX(50px); }
    to { opacity: 1; transform: translateX(0); }
  }

  @keyframes fadeInUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(196, 30, 58, 0.4); }
    50% { transform: scale(1.02); box-shadow: 0 0 20px 10px rgba(196, 30, 58, 0); }
  }

  @keyframes float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @keyframes typewriter {
    from { width: 0; }
    to { width: 100%; }
  }

  @keyframes blink {
    0%, 50% { border-color: var(--color-sand); }
    51%, 100% { border-color: transparent; }
  }

  @keyframes rotateEmoji {
    0% { transform: rotateY(0deg); }
    100% { transform: rotateY(360deg); }
  }

  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
    opacity: 0;
  }

  .scroll-reveal {
    opacity: 0;
    transition: all 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .scroll-reveal.visible {
    opacity: 1;
  }

  .scroll-reveal[data-direction="left"].visible {
    animation: fadeInLeft 0.8s ease-out forwards;
  }

  .scroll-reveal[data-direction="right"].visible {
    animation: fadeInRight 0.8s ease-out forwards;
  }

  .scroll-reveal[data-direction="up"].visible {
    animation: fadeInUp 0.8s ease-out forwards;
  }

  .btn-pulse {
    animation: pulse 2s infinite;
  }

  .btn-pulse:hover {
    animation: none;
  }

  .animate-bounce-hover {
    transition: transform 0.3s ease;
  }

  .animate-bounce-hover:hover {
    animation: float 1s ease-in-out infinite;
  }

  /* ===== FLOATING ORDER BUTTON ===== */
  .floating-order-btn {
    position: fixed;
    bottom: 2rem;
    right: 2rem;
    z-index: 1000;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 1.25rem;
    background: linear-gradient(135deg, var(--color-primary) 0%, #a01830 100%);
    color: white;
    border-radius: 50px;
    box-shadow: 0 4px 20px rgba(196, 30, 58, 0.4);
    transform: translateY(100px);
    opacity: 0;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    text-decoration: none;
    font-weight: 600;
  }

  .floating-order-btn.visible {
    transform: translateY(0);
    opacity: 1;
  }

  .floating-order-btn:hover {
    transform: translateY(-3px) scale(1.05);
    box-shadow: 0 6px 25px rgba(196, 30, 58, 0.5);
  }

  .floating-icon {
    font-size: 1.5rem;
    animation: float 2s ease-in-out infinite;
  }

  .floating-text {
    font-size: 0.9rem;
    white-space: nowrap;
  }

  /* ===== HERO SECTION ===== */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #8B4513 0%, #5D3A1A 50%, #2D1810 100%);
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 70%, rgba(196, 30, 58, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 70% 30%, rgba(244, 163, 0, 0.2) 0%, transparent 50%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30z' fill='%23fff' fill-opacity='1'/%3E%3C/svg%3E");
    background-size: 30px 30px;
    transition: transform 0.1s ease-out;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-md);
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(244, 163, 0, 0.2);
    border: 1px solid var(--color-tertiary);
    border-radius: 50px;
    color: var(--color-tertiary);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: var(--spacing-md);
  }

  .hero h1 {
    color: var(--color-text-white);
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: var(--spacing-sm);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-subtitle {
    color: var(--color-sand);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin-bottom: var(--spacing-lg);
    font-style: italic;
    min-height: 2.5rem;
    display: inline-block;
  }

  .hero-subtitle::after {
    content: '|';
    animation: blink 1s infinite;
    margin-left: 2px;
  }

  .hero-subtitle.typing-done::after {
    display: none;
  }

  .hero-ctas {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: var(--color-sand);
    font-size: 0.85rem;
    opacity: 0.7;
    animation: bounce 2s infinite;
    cursor: pointer;
    transition: opacity 0.3s ease;
  }

  .hero-scroll:hover {
    opacity: 1;
  }

  .scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid var(--color-sand);
    border-bottom: 2px solid var(--color-sand);
    transform: rotate(45deg);
    margin: 0.5rem auto 0;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  /* ===== ABOUT SECTION ===== */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .about-content .section-title {
    text-align: left;
  }

  .about-content .section-title::after {
    margin: var(--spacing-sm) 0 0;
  }

  .about-text {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--spacing-sm);
  }

  .about-image-placeholder {
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
    position: relative;
    overflow: hidden;
    cursor: pointer;
  }

  .interactive-image {
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .interactive-image:hover {
    transform: scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .interactive-image:hover .placeholder-icon {
    animation: rotateEmoji 0.6s ease-in-out;
  }

  .interactive-image:hover .image-overlay {
    opacity: 1;
  }

  .image-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 1rem;
    background: linear-gradient(to top, rgba(0,0,0,0.7), transparent);
    color: white;
    text-align: center;
    opacity: 0;
    transition: opacity 0.3s ease;
    font-size: 0.9rem;
  }

  .placeholder-content {
    text-align: center;
    color: white;
    transition: transform 0.3s ease;
  }

  .placeholder-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--spacing-sm);
    transition: transform 0.3s ease;
  }

  .placeholder-text {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
  }

  .stat {
    text-align: center;
    padding: var(--spacing-sm);
    background: white;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .stat:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-md);
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* ===== FEATURES SECTION ===== */
  .feature-card {
    padding: var(--spacing-md);
    text-align: center;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .feature-card:hover {
    transform: translateY(-10px);
    box-shadow: 0 15px 30px rgba(0, 0, 0, 0.15);
  }

  .feature-icon {
    font-size: 3rem;
    margin-bottom: var(--spacing-sm);
    display: inline-block;
  }

  .feature-card h3 {
    margin-bottom: var(--spacing-xs);
    color: var(--color-brown-dark);
  }

  .feature-card p {
    color: var(--color-text-light);
    font-size: 0.95rem;
    line-height: 1.7;
  }

  .feature-link {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    margin-top: var(--spacing-sm);
    color: var(--color-primary);
    font-weight: 600;
    transition: gap 0.3s ease;
  }

  .feature-link:hover {
    gap: 0.5rem;
  }

  .feature-link .arrow {
    transition: transform 0.3s ease;
  }

  .feature-link:hover .arrow {
    transform: translateX(5px);
  }

  /* ===== MENU PREVIEW - FLIP CARDS ===== */
  .menu-preview h2,
  .menu-preview .section-subtitle {
    color: var(--color-cream);
  }

  .menu-preview .section-title::after {
    background: linear-gradient(to right, var(--color-tertiary), var(--color-secondary));
  }

  .menu-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .flip-card {
    perspective: 1000px;
    height: 280px;
    background: transparent;
    padding: 0;
  }

  .flip-card-inner {
    position: relative;
    width: 100%;
    height: 100%;
    text-align: center;
    transition: transform 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    transform-style: preserve-3d;
  }

  .flip-card:hover .flip-card-inner {
    transform: rotateY(180deg);
  }

  .flip-card-front,
  .flip-card-back {
    position: absolute;
    width: 100%;
    height: 100%;
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    border-radius: var(--radius-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-md);
  }

  .flip-card-front {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .flip-card-back {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    transform: rotateY(180deg);
  }

  .category-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .flip-card h3,
  .menu-category h3 {
    color: var(--color-tertiary);
    margin-bottom: var(--spacing-xs);
  }

  .flip-card-back h3 {
    color: white;
    font-size: 1rem;
  }

  .flip-card p,
  .menu-category p {
    color: var(--color-sand);
    font-size: 0.9rem;
    margin: 0;
  }

  .popular-item {
    font-size: 1.25rem !important;
    font-weight: 700;
    color: var(--color-tertiary) !important;
    margin: 0.5rem 0 1rem !important;
  }

  .btn-sm {
    padding: 0.5rem 1rem;
    font-size: 0.85rem;
  }

  /* ===== TESTIMONIAL CAROUSEL ===== */
  .testimonial-carousel {
    position: relative;
    display: flex;
    align-items: center;
    max-width: 900px;
    margin: 0 auto;
    padding: 0 3rem;
  }

  .carousel-track-container {
    overflow: hidden;
    width: 100%;
  }

  .carousel-track {
    display: flex;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .testimonial-slide {
    min-width: 100%;
    padding: 0 1rem;
  }

  .carousel-btn {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 50px;
    height: 50px;
    border-radius: 50%;
    border: 2px solid var(--color-primary);
    background: white;
    color: var(--color-primary);
    font-size: 1.5rem;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
  }

  .carousel-btn:hover {
    background: var(--color-primary);
    color: white;
    transform: translateY(-50%) scale(1.1);
  }

  .carousel-prev {
    left: 0;
  }

  .carousel-next {
    right: 0;
  }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 0.5rem;
    margin-top: var(--spacing-md);
  }

  .carousel-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid var(--color-primary);
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
    padding: 0;
  }

  .carousel-dot.active,
  .carousel-dot:hover {
    background: var(--color-primary);
    transform: scale(1.2);
  }

  .testimonial-card {
    padding: var(--spacing-lg);
    position: relative;
    text-align: center;
    min-height: 200px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .quote-icon {
    font-size: 4rem;
    font-family: Georgia, serif;
    color: var(--color-tertiary);
    opacity: 0.3;
    position: absolute;
    top: 0.5rem;
    left: 1.5rem;
    line-height: 1;
  }

  .testimonial-card blockquote {
    position: relative;
    z-index: 1;
  }

  .testimonial-card p {
    font-size: 1.15rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.8;
    margin-bottom: var(--spacing-sm);
  }

  .testimonial-card footer {
    color: var(--color-primary);
    font-weight: 600;
    font-size: 1rem;
  }

  /* ===== CTA SECTION ===== */
  .cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: var(--spacing-xs);
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.1rem;
    margin-bottom: var(--spacing-md);
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta .btn-primary {
    background: white;
    color: var(--color-primary);
    border-color: white;
  }

  .cta .btn-primary:hover {
    background: var(--color-tertiary);
    border-color: var(--color-tertiary);
    color: var(--color-brown-dark);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .about-content {
      order: 1;
    }

    .about-visual {
      order: 0;
    }

    .about-content .section-title {
      text-align: center;
    }

    .about-content .section-title::after {
      margin: var(--spacing-sm) auto 0;
    }

    .about-content {
      text-align: center;
    }

    .testimonial-carousel {
      padding: 0 2.5rem;
    }

    .carousel-btn {
      width: 40px;
      height: 40px;
      font-size: 1.25rem;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 90vh;
    }

    .about-stats {
      grid-template-columns: 1fr;
    }

    .stat {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--spacing-sm);
    }

    .stat-number {
      font-size: 1.5rem;
    }

    .floating-order-btn {
      bottom: 1rem;
      right: 1rem;
      padding: 0.6rem 1rem;
    }

    .floating-text {
      display: none;
    }

    .flip-card {
      height: 240px;
    }

    .testimonial-carousel {
      padding: 0;
    }

    .carousel-btn {
      display: none;
    }

    .carousel-track-container {
      touch-action: pan-x;
    }
  }
</style>

<script>
  // ===== TYPEWRITER EFFECT =====
  const typewriterElement = document.getElementById('typewriter');
  const phrases = [
    'Where Comfort Food Meets Vibrant Tradition.',
    'Authentic Mexican Cuisine Since 1978.',
    'Family Recipes, Made With Love.',
    'Your Home Away From Home.'
  ];
  let phraseIndex = 0;
  let charIndex = 0;
  let isDeleting = false;
  let typingSpeed = 80;

  function typeWriter() {
    const currentPhrase = phrases[phraseIndex];

    if (isDeleting) {
      typewriterElement.textContent = currentPhrase.substring(0, charIndex - 1);
      charIndex--;
      typingSpeed = 40;
    } else {
      typewriterElement.textContent = currentPhrase.substring(0, charIndex + 1);
      charIndex++;
      typingSpeed = 80;
    }

    if (!isDeleting && charIndex === currentPhrase.length) {
      isDeleting = true;
      typingSpeed = 2000; // Pause at end
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      phraseIndex = (phraseIndex + 1) % phrases.length;
      typingSpeed = 500; // Pause before new phrase
    }

    setTimeout(typeWriter, typingSpeed);
  }

  typeWriter();

  // ===== SCROLL REVEAL ANIMATIONS =====
  const scrollRevealElements = document.querySelectorAll('.scroll-reveal');

  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.15
  };

  const scrollObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        scrollObserver.unobserve(entry.target);
      }
    });
  }, observerOptions);

  scrollRevealElements.forEach(element => {
    scrollObserver.observe(element);
  });

  // ===== ANIMATED COUNTERS =====
  const statsSection = document.getElementById('statsSection');
  const statNumbers = statsSection?.querySelectorAll('.stat-number');
  let countersAnimated = false;

  function animateCounters() {
    if (countersAnimated) return;

    statNumbers?.forEach(stat => {
      const target = parseInt(stat.getAttribute('data-count') || '0');
      const suffix = stat.getAttribute('data-suffix') || '';
      const duration = 2000;
      const increment = target / (duration / 16);
      let current = 0;

      const updateCounter = () => {
        current += increment;
        if (current < target) {
          stat.textContent = Math.floor(current).toLocaleString() + suffix;
          requestAnimationFrame(updateCounter);
        } else {
          stat.textContent = target.toLocaleString() + suffix;
        }
      };

      updateCounter();
    });

    countersAnimated = true;
  }

  const statsObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        animateCounters();
        statsObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.5 });

  if (statsSection) {
    statsObserver.observe(statsSection);
  }

  // ===== FLOATING ORDER BUTTON =====
  const floatingBtn = document.getElementById('floatingOrderBtn');
  const heroSection = document.getElementById('hero');

  function handleFloatingButton() {
    if (!heroSection || !floatingBtn) return;

    const heroHeight = heroSection.offsetHeight;
    const scrollY = window.scrollY;

    if (scrollY > heroHeight * 0.7) {
      floatingBtn.classList.add('visible');
    } else {
      floatingBtn.classList.remove('visible');
    }
  }

  window.addEventListener('scroll', handleFloatingButton, { passive: true });

  // ===== PARALLAX HERO PATTERN =====
  const heroPattern = document.getElementById('heroPattern');

  function handleParallax() {
    if (!heroPattern || !heroSection) return;

    const scrollY = window.scrollY;
    const heroHeight = heroSection.offsetHeight;

    if (scrollY < heroHeight) {
      const parallaxOffset = scrollY * 0.3;
      heroPattern.style.transform = `translateY(${parallaxOffset}px)`;
    }
  }

  window.addEventListener('scroll', handleParallax, { passive: true });

  // ===== TESTIMONIAL CAROUSEL =====
  const carouselTrack = document.getElementById('carouselTrack');
  const prevBtn = document.getElementById('prevBtn');
  const nextBtn = document.getElementById('nextBtn');
  const dots = document.querySelectorAll('.carousel-dot');
  const slides = document.querySelectorAll('.testimonial-slide');

  let currentSlide = 0;
  const totalSlides = slides.length;
  let autoPlayInterval: ReturnType<typeof setInterval>;

  function updateCarousel() {
    if (!carouselTrack) return;

    carouselTrack.style.transform = `translateX(-${currentSlide * 100}%)`;

    dots.forEach((dot, index) => {
      dot.classList.toggle('active', index === currentSlide);
    });
  }

  function nextSlide() {
    currentSlide = (currentSlide + 1) % totalSlides;
    updateCarousel();
  }

  function prevSlide() {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    updateCarousel();
  }

  function goToSlide(index: number) {
    currentSlide = index;
    updateCarousel();
  }

  function startAutoPlay() {
    autoPlayInterval = setInterval(nextSlide, 5000);
  }

  function stopAutoPlay() {
    clearInterval(autoPlayInterval);
  }

  // Event listeners
  nextBtn?.addEventListener('click', () => {
    stopAutoPlay();
    nextSlide();
    startAutoPlay();
  });

  prevBtn?.addEventListener('click', () => {
    stopAutoPlay();
    prevSlide();
    startAutoPlay();
  });

  dots.forEach((dot, index) => {
    dot.addEventListener('click', () => {
      stopAutoPlay();
      goToSlide(index);
      startAutoPlay();
    });
  });

  // Touch support for mobile
  let touchStartX = 0;
  let touchEndX = 0;

  carouselTrack?.addEventListener('touchstart', (e) => {
    touchStartX = e.touches[0].clientX;
    stopAutoPlay();
  }, { passive: true });

  carouselTrack?.addEventListener('touchend', (e) => {
    touchEndX = e.changedTouches[0].clientX;
    const diff = touchStartX - touchEndX;

    if (Math.abs(diff) > 50) {
      if (diff > 0) {
        nextSlide();
      } else {
        prevSlide();
      }
    }
    startAutoPlay();
  }, { passive: true });

  // Start autoplay
  startAutoPlay();

  // Pause on hover
  const carouselContainer = document.getElementById('testimonialCarousel');
  carouselContainer?.addEventListener('mouseenter', stopAutoPlay);
  carouselContainer?.addEventListener('mouseleave', startAutoPlay);

  // ===== ROTATING FOOD EMOJI =====
  const rotatingEmoji = document.getElementById('rotatingEmoji');
  const foodEmojis = ['🌮', '🌯', '🫔', '🌶️', '🍳', '🥑', '🧀', '🍅'];
  let emojiIndex = 0;

  const foodShowcase = document.getElementById('foodShowcase');
  foodShowcase?.addEventListener('click', () => {
    emojiIndex = (emojiIndex + 1) % foodEmojis.length;
    if (rotatingEmoji) {
      rotatingEmoji.style.transform = 'rotateY(180deg)';
      setTimeout(() => {
        rotatingEmoji.textContent = foodEmojis[emojiIndex];
        rotatingEmoji.style.transform = 'rotateY(360deg)';
      }, 150);
      setTimeout(() => {
        rotatingEmoji.style.transform = 'rotateY(0deg)';
      }, 300);
    }
  });

  // ===== SMOOTH SCROLL FOR HERO ARROW =====
  const heroScroll = document.querySelector('.hero-scroll');
  const aboutSection = document.querySelector('.about');

  heroScroll?.addEventListener('click', () => {
    aboutSection?.scrollIntoView({ behavior: 'smooth' });
  });
</script>
