---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    quote: "Delicious Mexican food with an authentic feel... the queso is a tasty twist on an old favorite.",
    author: "Dave S."
  },
  {
    quote: "Always an excellent experience at Su Casa. Their salsa is the best! The staff are always friendly.",
    author: "Victoria G."
  },
  {
    quote: "I've been going to Su Casa for decades and have never had a bad meal.",
    author: "Brett E."
  }
];

---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <div class="hero-overlay"></div>
    <div class="hero-pattern"></div>
    <div class="hero-content container">
      <span class="hero-badge">Family Owned Since 1978</span>
      <h1>Welcome to Su Casa Mexican Restaurant</h1>
      <p class="hero-subtitle">Where Comfort Food Meets Vibrant Tradition.</p>
      <div class="hero-ctas">
        <a href="/order" class="btn btn-primary">Order Online</a>
        <a href="/catering" class="btn btn-outline">Inquire for Catering</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll to explore</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section bg-pattern">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2 class="section-title">Our Story</h2>
          <p class="about-text">
            Family owned since 1978, our cozy and festive atmosphere has been home to delicious, Mexican cuisine that warms the soul. Every meal here feels like home.
          </p>
          <p class="about-text">
            For over four decades, we've been serving the Midvale community with authentic recipes passed down through generations. Our vibrant murals and warm hospitality reflect the heart and soul of Mexican culture.
          </p>
          <a href="/menu" class="btn btn-secondary">Explore Our Menu</a>
        </div>
        <div class="about-visual">
          <div class="about-image-placeholder">
            <div class="placeholder-content">
              <span class="placeholder-icon">🌮🌯🌶️</span>
              <span class="placeholder-text">Authentic Mexican Cuisine</span>
            </div>
          </div>
          <div class="about-stats">
            <div class="stat">
              <span class="stat-number">45+</span>
              <span class="stat-label">Years Serving</span>
            </div>
            <div class="stat">
              <span class="stat-number">100+</span>
              <span class="stat-label">Menu Items</span>
            </div>
            <div class="stat">
              <span class="stat-number">1000s</span>
              <span class="stat-label">Happy Customers</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Menu Preview Section -->
  <section class="menu-preview section bg-dark">
    <div class="container">
      <h2 class="section-title">Taste Our Favorites</h2>
      <p class="section-subtitle">From sizzling fajitas to handcrafted enchiladas</p>
      <div class="menu-preview-grid">
        <div class="menu-category">
          <span class="category-icon">🌯</span>
          <h3>Burritos</h3>
          <p>Stuffed with your choice of fillings and smothered in our signature sauces</p>
        </div>
        <div class="menu-category">
          <span class="category-icon">🌮</span>
          <h3>Tacos</h3>
          <p>Crispy or soft shell, filled with perfectly seasoned meats</p>
        </div>
        <div class="menu-category">
          <span class="category-icon">🫔</span>
          <h3>Enchiladas</h3>
          <p>Hand-rolled and covered in authentic red or green sauce</p>
        </div>
        <div class="menu-category">
          <span class="category-icon">🍳</span>
          <h3>Fajitas</h3>
          <p>Sizzling platters of steak or chicken with peppers and onions</p>
        </div>
      </div>
      <div class="text-center mt-lg">
        <a href="/menu" class="btn btn-secondary">View Full Menu</a>
      </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials section bg-cream">
    <div class="container">
      <h2 class="section-title">What Our Guests Say</h2>
      <p class="section-subtitle">Join thousands of satisfied customers who call Su Casa their favorite</p>
      <div class="testimonials-grid grid grid-3">
        {testimonials.map((testimonial) => (
          <div class="testimonial-card card">
            <div class="quote-icon">"</div>
            <blockquote>
              <p>{testimonial.quote}</p>
              <footer>— {testimonial.author}</footer>
            </blockquote>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section">
    <div class="container">
      <div class="cta-content">
        <h2>Ready to Experience Su Casa?</h2>
        <p>Visit us today or order online for pickup and delivery</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary">Find Our Location</a>
          <a href="/order" class="btn btn-secondary">Order Online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #415f84 0%, #66596e 50%, #000000 100%);
    overflow: hidden;
  }

  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 70%, rgba(209, 97, 93, 0.3) 0%, transparent 50%),
      radial-gradient(circle at 70% 30%, rgba(242, 186, 101, 0.2) 0%, transparent 50%);
  }

  .hero-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.05;
    background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M30 0L60 30L30 60L0 30z' fill='%23fff' fill-opacity='1'/%3E%3C/svg%3E");
    background-size: 30px 30px;
  }

  .hero-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: var(--spacing-md);
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(244, 163, 0, 0.2);
    border: 1px solid var(--color-tertiary);
    border-radius: 50px;
    color: var(--color-tertiary);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: var(--spacing-md);
  }

  .hero h1 {
    color: var(--color-text-white);
    font-size: clamp(2.5rem, 6vw, 4rem);
    margin-bottom: var(--spacing-sm);
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
  }

  .hero-subtitle {
    color: var(--color-sand);
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin-bottom: var(--spacing-lg);
    font-style: italic;
  }

  .hero-ctas {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: var(--color-sand);
    font-size: 0.85rem;
    opacity: 0.7;
    animation: bounce 2s infinite;
  }

  .scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid var(--color-sand);
    border-bottom: 2px solid var(--color-sand);
    transform: rotate(45deg);
    margin: 0.5rem auto 0;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  /* About Section */
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .about-content .section-title {
    text-align: left;
  }

  .about-content .section-title::after {
    margin: var(--spacing-sm) 0 0;
  }

  .about-text {
    font-size: 1.1rem;
    color: var(--color-text-light);
    line-height: 1.8;
    margin-bottom: var(--spacing-sm);
  }

  .about-image-placeholder {
    aspect-ratio: 4/3;
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-secondary) 100%);
    border-radius: var(--radius-lg);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
  }

  .placeholder-content {
    text-align: center;
    color: white;
  }

  .placeholder-icon {
    font-size: 4rem;
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .placeholder-text {
    font-size: 1.25rem;
    font-weight: 600;
  }

  .about-stats {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--spacing-sm);
    margin-top: var(--spacing-md);
  }

  .stat {
    text-align: center;
    padding: var(--spacing-sm);
    background: white;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .stat-number {
    display: block;
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    font-family: var(--font-heading);
  }

  .stat-label {
    font-size: 0.85rem;
    color: var(--color-text-light);
  }

  /* Menu Preview */
  .menu-preview h2,
  .menu-preview .section-subtitle {
    color: var(--color-cream);
  }

  .menu-preview .section-title::after {
    background: linear-gradient(to right, var(--color-tertiary), var(--color-secondary));
  }

  .menu-preview-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .menu-category {
    text-align: center;
    padding: var(--spacing-md);
    background: rgba(255, 255, 255, 0.05);
    border-radius: var(--radius-lg);
    border: 1px solid rgba(255, 255, 255, 0.1);
    transition: all var(--transition-normal);
  }

  .menu-category:hover {
    background: rgba(255, 255, 255, 0.1);
    transform: translateY(-5px);
  }

  .category-icon {
    font-size: 3rem;
    display: block;
    margin-bottom: var(--spacing-sm);
  }

  .menu-category h3 {
    color: var(--color-tertiary);
    margin-bottom: var(--spacing-xs);
  }

  .menu-category p {
    color: var(--color-sand);
    font-size: 0.9rem;
    margin: 0;
  }

  /* Testimonials */
  .testimonial-card {
    padding: var(--spacing-md);
    position: relative;
    text-align: center;
  }

  .quote-icon {
    font-size: 4rem;
    font-family: Georgia, serif;
    color: var(--color-tertiary);
    opacity: 0.3;
    position: absolute;
    top: 0.5rem;
    left: 1rem;
    line-height: 1;
  }

  .testimonial-card blockquote {
    position: relative;
    z-index: 1;
  }

  .testimonial-card p {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--spacing-sm);
  }

  .testimonial-card footer {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* CTA Section */
  .cta {
    background: linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%);
    text-align: center;
  }

  .cta-content h2 {
    color: white;
    margin-bottom: var(--spacing-xs);
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.9);
    font-size: 1.1rem;
    margin-bottom: var(--spacing-md);
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta .btn-primary {
    background: white;
    color: var(--color-primary);
    border-color: white;
  }

  .cta .btn-primary:hover {
    background: var(--color-tertiary);
    border-color: var(--color-tertiary);
    color: var(--color-brown-dark);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .about-content {
      order: 1;
    }

    .about-visual {
      order: 0;
    }

    .about-content .section-title {
      text-align: center;
    }

    .about-content .section-title::after {
      margin: var(--spacing-sm) auto 0;
    }

    .about-content {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 90vh;
    }

    .about-stats {
      grid-template-columns: 1fr;
    }

    .stat {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: var(--spacing-sm);
    }

    .stat-number {
      font-size: 1.5rem;
    }
  }
</style>
