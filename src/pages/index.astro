---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import collageMexicanDinner from '../assets/images/collage/mexican-dinner.jpg';
import collageNachoSupreme from '../assets/images/collage/nacho-supreme.jpg';
import collageQuesoDip from '../assets/images/collage/queso-dip.jpg';
import mediaComboPlate from '../assets/images/media/combo-plate-10.jpg';
import mediaChileRelleno from '../assets/images/media/chili-relleno.jpg';
import mediaChileVerde from '../assets/images/media/chile-verde-dinner.jpg';

const testimonials = [
  {
    quote: "Delicious Mexican food with an authentic feel... the queso is a tasty twist on an old favorite.",
    author: "Dave S."
  },
  {
    quote: "Always an excellent experience at Su Casa. Their salsa is the best! The staff are always friendly.",
    author: "Victoria G."
  },
  {
    quote: "I've been going to Su Casa for decades and have never had a bad meal.",
    author: "Brett E."
  }
];



const siteUrl = 'https://sucasamexicanrestaurant.com';

const restaurantSchema = {
  "@context": "https://schema.org",
  "@type": "Restaurant",
  "name": "Su Casa Mexican Restaurant",
  "image": "https://sucasamexicanrestaurant.com/_astro/logo.ChkLogVw_XKnHR.webp",
  "url": "https://sucasamexicanrestaurant.com",
  "telephone": "+1-801-255-1042",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "6878 S State Street",
    "addressLocality": "Midvale",
    "addressRegion": "UT",
    "postalCode": "84047",
    "addressCountry": "US"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 40.6264145,
    "longitude": -111.8904448
  },
  "servesCuisine": ["Mexican", "Tex-Mex", "Latin American"],
  "priceRange": "$$",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday"],
      "opens": "11:00",
      "closes": "20:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Friday","Saturday"],
      "opens": "11:00",
      "closes": "21:00"
    }
  ],
  "menu": "https://sucasamexicanrestaurant.com/menu",
  "hasMenu": {
    "@type": "Menu",
    "url": "https://sucasamexicanrestaurant.com/menu"
  },
  "acceptsReservations": "No",
  "foundingDate": "1978",
  "description": "Family-owned since 1978, Su Casa serves authentic Mexican food in Midvale, UT. Dine in, order online, or cater your next event.",
  "sameAs": [
    "https://www.instagram.com/sucasamidvale/",
    "https://www.yelp.com/biz/su-casa-mexican-restaurant-midvale",
    "https://www.doordash.com/store/su-casa-mexican-restaurant-midvale-922561/",
    "https://www.grubhub.com/restaurant/su-casa-mexican-restaurant-6878-state-st-midvale/1472764"
  ],
  "potentialAction": {
    "@type": "OrderAction",
    "target": {
      "@type": "EntryPoint",
      "urlTemplate": "https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/"
    },
    "deliveryMethod": ["http://purl.org/goodrelations/v1#DeliveryModePickUp"]
  }
};

const webSiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": `${siteUrl}/#website`,
  "name": "Su Casa Mexican Restaurant",
  "url": siteUrl,
  "publisher": { "@id": `${siteUrl}/#restaurant` }
};

const webPageSchema = {
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": `${siteUrl}/`,
  "name": "Su Casa Mexican Restaurant | Authentic Mexican Food in Midvale, UT",
  "description": "Family owned since 1978, Su Casa Mexican Restaurant in Midvale, UT offers authentic Mexican cuisine in a cozy, festive atmosphere.",
  "url": siteUrl,
  "isPartOf": { "@id": `${siteUrl}/#website` },
  "about": { "@id": `${siteUrl}/#restaurant` }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": siteUrl
    }
  ]
};
---

<Layout title="Home">
  <Fragment slot="head">
    <script type="application/ld+json" set:html={JSON.stringify(restaurantSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webSiteSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
  </Fragment>
  <!-- Hero Section -->
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="/media/banner-video.mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-pattern"></div>
    <div class="hero-content container">
      <h1>WELCOME TO SU CASA</h1>
      <p class="hero-tagline">Family Owned Since 1978</p>
      <div class="hero-ctas">
        <a href="/order" class="btn btn-primary">ORDER ONLINE</a>
        <a href="/catering" class="btn btn-outline">Inquire for Catering</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll to explore</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2 class="section-title fade-in-element">OUR STORY</h2>
          <p class="about-text fade-in-element" style="--delay: 0.1s">
            Founded by longtime restaurateur Fred Osterloh, Su Casa Mexican Restaurant is rooted in a love for bold flavors, homemade recipes, and doing things the right way. Years before opening Su Casa, Fred spent time traveling, tasting, and carefully refining recipes—laying the groundwork for the menu long before the doors ever opened.
          </p>
          <p class="about-text fade-in-element" style="--delay: 0.2s">
            After opening several beloved restaurants, including Frederico's, Fred's Burger Chalet, and his first Mexican restaurant, El Sol, Fred brought everything he learned together when he opened Su Casa in June of 1978.
          </p>
          <p class="about-text fade-in-element" style="--delay: 0.3s">
            After Fred's retirement in 1999, the restaurant was passed down to his youngest son, Michael Osterloh, and today continues under the care of Denice Osterloh, carrying on the same comforting food and welcoming atmosphere Midvale has loved for generations.
          </p>
        </div>
        <div class="about-visual">
          <div class="about-image-container slide-in-image">
            <img src="https://i.postimg.cc/Qd38H8mx/IMG-5925.avif" alt="Su Casa Mexican Restaurant" class="about-image" width="1200" height="900" loading="lazy" decoding="async" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Collage Section -->
  <section class="photo-collage">
    <div class="collage-grid">
        <div class="collage-item collage-item-1">
          <Image src={collageMexicanDinner} alt="Mexican Dinner" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Mexican Dinner</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-2">
          <img src="https://i.postimg.cc/fyGxtdST/Copy-of-special-burrito-copy.jpg" alt="Special Burrito" width="800" height="534" loading="lazy" decoding="async" />
          <div class="collage-overlay">
            <span class="dish-name">Special Burrito</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-3">
          <Image src={collageNachoSupreme} alt="Nacho Supreme" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Nacho Supreme</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-4">
          <Image src={collageQuesoDip} alt="Queso Dip" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Queso Dip</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-5">
          <img src="https://i.postimg.cc/RVwKn077/Copy-of-7-copy.jpg" alt="#7 Burrito verde, bean tostada & cheese enchilada" width="800" height="534" loading="lazy" decoding="async" />
          <div class="collage-overlay">
            <span class="dish-name">#7 Burrito verde, bean tostada & cheese enchilada</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-6">
          <img src="https://i.postimg.cc/Y0jvKXt6/Copy-of-baja-dinner-(2).jpg" alt="Baja Fish Tacos" width="800" height="534" loading="lazy" decoding="async" />
          <div class="collage-overlay">
            <span class="dish-name">Baja Fish Tacos</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-7">
          <Image src={mediaComboPlate} alt="#10 Bean Tostada" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">#10 Bean Tostada</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-8">
          <Image src={mediaChileRelleno} alt="Chile Relleno" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Chile Relleno</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
        <div class="collage-item collage-item-9">
          <Image src={mediaChileVerde} alt="Chile Verde Dinner" width={800} loading="lazy" />
          <div class="collage-overlay">
            <span class="dish-name">Chile Verde Dinner</span>
            <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" class="order-btn" target="_blank" rel="noopener">Order Now</a>
          </div>
        </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials section">
    <div class="container">
      <h2 class="section-title">WHAT OUR GUESTS SAY</h2>
      <p class="section-subtitle">Join thousands of satisfied customers who call Su Casa their favorite</p>
      <div class="testimonials-grid grid grid-3">
        {testimonials.map((testimonial) => (
          <div class="testimonial-card card">
            <div class="quote-icon">"</div>
            <blockquote>
              <p>{testimonial.quote}</p>
              <footer>— {testimonial.author}</footer>
            </blockquote>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section">
    <div class="container">
      <div class="cta-grid">
        <div class="cta-map-container">
          <a href="https://www.google.com/maps/place/Su+Casa+Mexican+Restaurant/@40.6264145,-111.8904448,17z/data=!3m1!4b1!4m6!3m5!1s0x875289b066322b6f:0x1b428f9fb0f21030!8m2!3d40.6264145!4d-111.8904448!16s%2Fg%2F1tffvdvd?entry=ttu" target="_blank" rel="noopener" class="map-link">
            <iframe
              src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3026.5!2d-111.8926335!3d40.6264145!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x875289b066322b6f%3A0x1b428f9fb0f21030!2sSu%20Casa%20Mexican%20Restaurant!5e0!3m2!1sen!2sus!4v1706489600000!5m2!1sen!2sus"
              width="100%"
              height="100%"
              style="border:0;"
              allowfullscreen=""
              loading="lazy"
              referrerpolicy="no-referrer-when-downgrade"
              title="Su Casa Mexican Restaurant location on Google Maps">
            </iframe>
            <div class="map-overlay">
              <span class="directions-text">Get Directions</span>
            </div>
          </a>
          <a href="https://share.google/5fDBzyKZfgpYTgiUf" target="_blank" rel="noopener" class="gbp-link">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 92.3 132.3" width="20" height="28" class="maps-icon">
              <path fill="#1a73e8" d="M60.2 2.2C55.8.8 51 0 46.1 0 32 0 19.3 6.4 10.8 16.5l21.8 18.3L60.2 2.2z"/>
              <path fill="#ea4335" d="M10.8 16.5C4.1 24.5 0 34.9 0 46.1c0 8.7 1.7 15.7 4.6 22l28-33.3-21.8-18.3z"/>
              <path fill="#4285f4" d="M46.2 28.5c9.8 0 17.7 7.9 17.7 17.7 0 4.3-1.6 8.3-4.2 11.4 0 0 13.9-16.6 27.5-32.7-5.6-10.8-15.3-19-27-22.7L32.6 34.8c3.3-3.8 8.1-6.3 13.6-6.3z"/>
              <path fill="#fbbc04" d="M46.2 63.8c-9.8 0-17.7-7.9-17.7-17.7 0-4.3 1.5-8.3 4.1-11.3l-28 33.3c4.8 10.6 12.8 19.2 21 29.9l34.1-40.5c-3.3 3.9-8.1 6.3-13.5 6.3z"/>
              <path fill="#34a853" d="M59.1 109.2c15.4-24.1 33.3-35 33.3-63 0-7.7-1.9-14.9-5.2-21.3L25.6 98c2.6 3.4 5.3 7.3 7.9 11.3 9.4 14.5 6.8 23.1 12.8 23.1s3.4-8.7 12.8-23.2z"/>
            </svg>
            <span>Find us on Google</span>
          </a>
        </div>
        <div class="cta-content">
          <h2>READY TO EXPERIENCE SU CASA?</h2>
          <p>Visit us today or order online for pickup and delivery</p>
          <div class="cta-buttons">
            <a href="/order" class="btn btn-secondary">Order Online</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Newsletter Signup Section -->
  <section class="newsletter section">
    <div class="container">
      <div class="newsletter-content">
        <h2>STAY UPDATED!</h2>
        <a href="https://l.spoton.com/mmAbKB" target="_blank" rel="noopener noreferrer" class="btn newsletter-btn">Sign up for our newsletter</a>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 115vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    overflow: hidden;
    margin-top: -140px;
    padding-top: 140px;
  }

  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .hero-pattern {
    display: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--spacing-md);
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(244, 163, 0, 0.2);
    border: 1px solid var(--color-tertiary);
    border-radius: 50px;
    color: var(--color-tertiary);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: var(--spacing-md);
  }

  .hero h1 {
    color: #ffffff;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    white-space: nowrap;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  }

  .hero-tagline {
    color: #ffffff;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin-bottom: var(--spacing-lg);
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .hero-ctas .btn-primary {
    padding: 1.25rem 3.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 2px;
    border-radius: 12px;
    background-color: #74bab1;
    border-color: #74bab1;
    color: #ffffff;
    transition: all 0.3s ease;
  }

  .hero-ctas .btn-primary:hover {
    background-color: #8eccc4;
    border-color: #8eccc4;
    color: #ffffff;
    transform: translateY(-3px) scale(1.05);
    box-shadow: none;
    outline: 4px solid #f2ba65;
    outline-offset: 2px;
  }

  .hero-ctas .btn-outline {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 1px;
    border-radius: 12px;
  }

  .hero .btn-outline {
    color: #ffffff;
    border-color: #ffffff;
  }

  .hero .btn-outline:hover {
    background-color: #ffffff;
    color: #000000;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: #ffffff;
    font-size: 0.85rem;
    opacity: 0.7;
    animation: bounce 2s infinite;
    z-index: 2;
  }

  .scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid #ffffff;
    border-bottom: 2px solid #ffffff;
    transform: rotate(45deg);
    margin: 0.5rem auto 0;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  /* About Section */
  .about {
    background: #74bab1;
  }

  .about .section-title {
    color: #000000;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .about-content .section-title {
    text-align: left;
  }

  .about-content .section-title::after {
    display: none;
  }

  .about-text {
    font-size: 1.1rem;
    color: #000000;
    line-height: 1.8;
    margin-bottom: var(--spacing-sm);
  }

  .about-image-container {
    aspect-ratio: 4/3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .about-image-container:hover {
    transform: scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .about-image-container:hover .about-image {
    transform: scale(1.08);
  }

  .slide-in-image {
    opacity: 0;
    transform: translateX(100px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out, box-shadow 0.4s ease;
  }

  .slide-in-image.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .slide-in-image.visible:hover {
    transform: scale(1.02);
  }

  /* Fade-in animations for text elements */
  .fade-in-element {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    transition-delay: var(--delay, 0s);
  }

  .fade-in-element.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .about-content .section-title.fade-in-element {
    transform: translateY(30px) scale(0.95);
  }

  .about-content .section-title.fade-in-element.visible {
    transform: translateY(0) scale(1);
  }

  /* Photo Collage */
  .photo-collage {
    background: #1a1a1a;
    padding: 4px 0;
  }

  .collage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(3, 250px);
    gap: 4px;
  }

  .collage-item {
    overflow: hidden;
    position: relative;
  }

  .collage-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collage-item:hover img {
    transform: scale(1.08);
  }

  .collage-item::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0, 0, 0, 0.3));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .collage-item:hover::after {
    opacity: 1;
  }

  /* Collage Overlay Styles */
  .collage-overlay {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.4) 50%, transparent 100%);
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    align-items: center;
    padding: 1.5rem 1rem;
    opacity: 0;
    transition: opacity 0.3s ease;
