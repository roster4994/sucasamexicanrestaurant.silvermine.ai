---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  {
    quote: "Delicious Mexican food with an authentic feel... the queso is a tasty twist on an old favorite.",
    author: "Dave S."
  },
  {
    quote: "Always an excellent experience at Su Casa. Their salsa is the best! The staff are always friendly.",
    author: "Victoria G."
  },
  {
    quote: "I've been going to Su Casa for decades and have never had a bad meal.",
    author: "Brett E."
  }
];

---

<Layout title="Home">
  <!-- Hero Section -->
  <section class="hero">
    <video class="hero-video" autoplay muted loop playsinline>
      <source src="/media/DSC Banner Video (2).mp4" type="video/mp4">
    </video>
    <div class="hero-overlay"></div>
    <div class="hero-pattern"></div>
    <div class="hero-content container">
      <h1>WELCOME TO SU CASA</h1>
      <p class="hero-tagline">Family Owned Since 1978</p>
      <div class="hero-ctas">
        <a href="/order" class="btn btn-primary">ORDER ONLINE</a>
        <a href="/catering" class="btn btn-outline">Inquire for Catering</a>
      </div>
    </div>
    <div class="hero-scroll">
      <span>Scroll to explore</span>
      <div class="scroll-arrow"></div>
    </div>
  </section>

  <!-- About Section -->
  <section class="about section">
    <div class="container">
      <div class="about-grid">
        <div class="about-content">
          <h2 class="section-title fade-in-element">OUR STORY</h2>
          <p class="about-text fade-in-element" style="--delay: 0.1s">
            Founded by longtime restaurateur Fred Osterloh, Su Casa Mexican Restaurant is rooted in a love for bold flavors, homemade recipes, and doing things the right way. Years before opening Su Casa, Fred spent time traveling, tasting, and carefully refining recipes—laying the groundwork for the menu long before the doors ever opened.
          </p>
          <p class="about-text fade-in-element" style="--delay: 0.2s">
            After opening several beloved restaurants, including Frederico's, Fred's Burger Chalet, and his first Mexican restaurant, El Sol, Fred brought everything he learned together when he opened Su Casa in June of 1978.
          </p>
          <p class="about-text fade-in-element" style="--delay: 0.3s">
            After Fred's retirement in 1999, the restaurant was passed down to his youngest son, Michael Osterloh, and today continues under the care of Denice Osterloh, carrying on the same comforting food and welcoming atmosphere Midvale has loved for generations.
          </p>
        </div>
        <div class="about-visual">
          <div class="about-image-container slide-in-image">
            <img src="https://i.postimg.cc/Qd38H8mx/IMG-5925.avif" alt="Su Casa Mexican Restaurant" class="about-image" />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Photo Collage Section -->
  <section class="photo-collage">
    <div class="collage-grid">
        <div class="collage-item collage-item-1">
          <img src="/collage/Copy of Mexican dinner copy (1).jpg" alt="Mexican Dinner" />
        </div>
        <div class="collage-item collage-item-2">
          <img src="https://i.postimg.cc/fyGxtdST/Copy-of-special-burrito-copy.jpg" alt="Special Burrito" />
        </div>
        <div class="collage-item collage-item-3">
          <img src="/collage/Copy of nacho supreme-1167 (1).jpg" alt="Nacho Supreme" />
        </div>
        <div class="collage-item collage-item-4">
          <img src="/collage/Copy of queso dip pic (2).jpg" alt="Queso Dip" />
        </div>
        <div class="collage-item collage-item-5">
          <img src="https://i.postimg.cc/RVwKn077/Copy-of-7-copy.jpg" alt="Mexican Dish" />
        </div>
        <div class="collage-item collage-item-6">
          <img src="https://i.postimg.cc/Y0jvKXt6/Copy-of-baja-dinner-(2).jpg" alt="Baja Dinner" />
        </div>
    </div>
  </section>

  <!-- Testimonials Section -->
  <section class="testimonials section">
    <div class="container">
      <h2 class="section-title">WHAT OUR GUESTS SAY</h2>
      <p class="section-subtitle">Join thousands of satisfied customers who call Su Casa their favorite</p>
      <div class="testimonials-grid grid grid-3">
        {testimonials.map((testimonial) => (
          <div class="testimonial-card card">
            <div class="quote-icon">"</div>
            <blockquote>
              <p>{testimonial.quote}</p>
              <footer>— {testimonial.author}</footer>
            </blockquote>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="cta section">
    <div class="container">
      <div class="cta-content">
        <h2>READY TO EXPERIENCE SU CASA?</h2>
        <p>Visit us today or order online for pickup and delivery</p>
        <div class="cta-buttons">
          <a href="/contact" class="btn btn-primary find-location">Find Our Location</a>
          <a href="/order" class="btn btn-secondary">Order Online</a>
        </div>
      </div>
    </div>
  </section>
</Layout>

<style>
  /* Hero Section */
  .hero {
    position: relative;
    min-height: 115vh;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #000;
    overflow: hidden;
    margin-top: -140px;
    padding-top: 140px;
  }

  .hero-video {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    z-index: 0;
  }

  .hero-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.4);
    z-index: 1;
  }

  .hero-pattern {
    display: none;
  }

  .hero-content {
    position: relative;
    z-index: 2;
    text-align: center;
    padding: var(--spacing-md);
    max-width: 800px;
  }

  .hero-badge {
    display: inline-block;
    padding: 0.5rem 1.5rem;
    background: rgba(244, 163, 0, 0.2);
    border: 1px solid var(--color-tertiary);
    border-radius: 50px;
    color: var(--color-tertiary);
    font-size: 0.9rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 2px;
    margin-bottom: var(--spacing-md);
  }

  .hero h1 {
    color: #ffffff;
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    margin-bottom: var(--spacing-sm);
    white-space: nowrap;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.5);
  }

  .hero-tagline {
    color: #ffffff;
    font-size: clamp(1.25rem, 3vw, 1.75rem);
    margin-bottom: var(--spacing-lg);
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.5);
  }

  .hero-ctas {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--spacing-md);
  }

  .hero-ctas .btn-primary {
    padding: 1.25rem 3.5rem;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: 2px;
    border-radius: 12px;
    background-color: #74bab1;
    border-color: #74bab1;
    color: #ffffff;
    transition: all 0.3s ease;
  }

  .hero-ctas .btn-primary:hover {
    background-color: #8eccc4;
    border-color: #8eccc4;
    color: #ffffff;
    transform: translateY(-3px) scale(1.05);
    box-shadow: none;
    outline: 4px solid #f2ba65;
    outline-offset: 2px;
  }

  .hero-ctas .btn-outline {
    padding: 1rem 2.5rem;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 1px;
    border-radius: 12px;
  }

  .hero .btn-outline {
    color: #ffffff;
    border-color: #ffffff;
  }

  .hero .btn-outline:hover {
    background-color: #ffffff;
    color: #000000;
  }

  .hero-scroll {
    position: absolute;
    bottom: 2rem;
    left: 50%;
    transform: translateX(-50%);
    text-align: center;
    color: #ffffff;
    font-size: 0.85rem;
    opacity: 0.7;
    animation: bounce 2s infinite;
    z-index: 2;
  }

  .scroll-arrow {
    width: 20px;
    height: 20px;
    border-right: 2px solid #ffffff;
    border-bottom: 2px solid #ffffff;
    transform: rotate(45deg);
    margin: 0.5rem auto 0;
  }

  @keyframes bounce {
    0%, 20%, 50%, 80%, 100% { transform: translateX(-50%) translateY(0); }
    40% { transform: translateX(-50%) translateY(-10px); }
    60% { transform: translateX(-50%) translateY(-5px); }
  }

  /* About Section */
  .about {
    background: #74bab1;
  }

  .about .section-title {
    color: #000000;
  }

  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-xl);
    align-items: center;
  }

  .about-content .section-title {
    text-align: left;
  }

  .about-content .section-title::after {
    display: none;
  }

  .about-text {
    font-size: 1.1rem;
    color: #000000;
    line-height: 1.8;
    margin-bottom: var(--spacing-sm);
  }

  .about-image-container {
    aspect-ratio: 4/3;
    border-radius: var(--radius-lg);
    overflow: hidden;
    box-shadow: var(--shadow-lg);
    cursor: pointer;
    transition: transform 0.4s ease, box-shadow 0.4s ease;
  }

  .about-image-container:hover {
    transform: scale(1.02);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3);
  }

  .about-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.6s ease;
  }

  .about-image-container:hover .about-image {
    transform: scale(1.08);
  }

  .slide-in-image {
    opacity: 0;
    transform: translateX(100px);
    transition: opacity 0.8s ease-out, transform 0.8s ease-out, box-shadow 0.4s ease;
  }

  .slide-in-image.visible {
    opacity: 1;
    transform: translateX(0);
  }

  .slide-in-image.visible:hover {
    transform: scale(1.02);
  }

  /* Fade-in animations for text elements */
  .fade-in-element {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    transition-delay: var(--delay, 0s);
  }

  .fade-in-element.visible {
    opacity: 1;
    transform: translateY(0);
  }

  .about-content .section-title.fade-in-element {
    transform: translateY(30px) scale(0.95);
  }

  .about-content .section-title.fade-in-element.visible {
    transform: translateY(0) scale(1);
  }

  /* Photo Collage */
  .photo-collage {
    background: #1a1a1a;
    padding: 4px 0;
  }

  .collage-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-template-rows: repeat(2, 250px);
    gap: 4px;
  }

  .collage-item {
    overflow: hidden;
    position: relative;
  }

  .collage-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .collage-item:hover img {
    transform: scale(1.08);
  }

  .collage-item::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(to bottom, transparent 60%, rgba(0, 0, 0, 0.3));
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .collage-item:hover::after {
    opacity: 1;
  }

  @media (max-width: 768px) {
    .collage-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-template-rows: repeat(3, 200px);
    }
  }

  @media (max-width: 480px) {
    .collage-grid {
      grid-template-columns: 1fr;
      grid-template-rows: repeat(6, 200px);
    }
  }

  /* Testimonials */
  .testimonials {
    background: #d1615d;
  }

  .testimonials .section-title {
    color: #000000;
  }

  .testimonials .section-title::after {
    display: none;
  }

  .testimonials .section-subtitle {
    color: #000000;
  }

  .testimonial-card {
    padding: var(--spacing-md);
    position: relative;
    text-align: center;
  }

  .quote-icon {
    font-size: 4rem;
    font-family: Georgia, serif;
    color: var(--color-tertiary);
    opacity: 0.3;
    position: absolute;
    top: 0.5rem;
    left: 1rem;
    line-height: 1;
  }

  .testimonial-card blockquote {
    position: relative;
    z-index: 1;
  }

  .testimonial-card p {
    font-size: 1.05rem;
    font-style: italic;
    color: var(--color-text);
    line-height: 1.7;
    margin-bottom: var(--spacing-sm);
  }

  .testimonial-card footer {
    color: var(--color-primary);
    font-weight: 600;
  }

  /* CTA Section */
  .cta {
    background: #f2ba65;
    text-align: center;
  }

  .cta-content h2 {
    color: #000000;
    margin-bottom: var(--spacing-xs);
  }

  .cta-content p {
    color: #000000;
    font-size: 1.1rem;
    margin-bottom: var(--spacing-md);
  }

  .cta-buttons {
    display: flex;
    gap: var(--spacing-sm);
    justify-content: center;
    flex-wrap: wrap;
  }

  .cta .btn-primary {
    background: white;
    color: var(--color-primary);
    border-color: white;
  }

  .cta .btn-primary.find-location {
    color: var(--color-brown-dark);
  }

  .cta .btn-primary.find-location:hover {
    background: var(--color-primary);
    border-color: var(--color-primary);
    color: #ffffff;
  }

  .cta .btn-primary:hover {
    background: var(--color-tertiary);
    border-color: var(--color-tertiary);
    color: var(--color-brown-dark);
  }

  .cta .btn-secondary {
    background: #ffffff;
    color: var(--color-brown-dark);
    border: 2px solid #ffffff;
  }

  .cta .btn-secondary:hover {
    background: var(--color-primary);
    color: #ffffff;
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  /* Responsive */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: var(--spacing-lg);
    }

    .about-content {
      order: 1;
    }

    .about-visual {
      order: 0;
    }

    .about-content .section-title {
      text-align: center;
    }

    .about-content .section-title::after {
      margin: var(--spacing-sm) auto 0;
    }

    .about-content {
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    .hero {
      min-height: 105vh;
    }

    .hero h1 {
      white-space: normal;
      text-align: center;
    }

    .hero-ctas .btn-primary {
      padding: 1rem 2.5rem;
      font-size: 1.25rem;
    }

    .hero-ctas .btn-outline {
      padding: 0.875rem 2rem;
      font-size: 1rem;
    }
  }
</style>

<script>
  // Scroll-triggered animations
  document.addEventListener('DOMContentLoaded', () => {
    const animatedElements = document.querySelectorAll('.slide-in-image, .fade-in-element');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, {
      threshold: 0.2,
      rootMargin: '0px 0px -50px 0px'
    });

    animatedElements.forEach(el => observer.observe(el));

    // Add subtle parallax effect on mouse move for the image
    const aboutSection = document.querySelector('.about');
    const aboutImage = document.querySelector('.about-image-container');

    if (aboutSection && aboutImage) {
      aboutSection.addEventListener('mousemove', (e) => {
        const rect = aboutSection.getBoundingClientRect();
        const x = (e.clientX - rect.left) / rect.width - 0.5;
        const y = (e.clientY - rect.top) / rect.height - 0.5;

        if (aboutImage.classList.contains('visible')) {
          aboutImage.style.transform = `translateX(${x * 10}px) translateY(${y * 10}px)`;
        }
      });

      aboutSection.addEventListener('mouseleave', () => {
        if (aboutImage.classList.contains('visible')) {
          aboutImage.style.transform = 'translateX(0) translateY(0)';
        }
      });
    }
  });
</script>
