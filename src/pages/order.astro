---
import Layout from '../layouts/Layout.astro';

const deliveryPartners = [
  {
    name: "DoorDash",
    link: "https://www.doordash.com/store/su-casa-mexican-restaurant-midvale-922561/",
    color: "#d1615d"
  },
  {
    name: "GrubHub",
    link: "https://www.grubhub.com/restaurant/su-casa-mexican-restaurant-6878-state-st-midvale/1472764?orderMethod=delivery&locationMode=DELIVERY&facetSet=umamiV2&pageSize=20&hideHateos=true&searchMetrics=true&queryText=Su%20Casa%20Mexican%20Restaurant&latitude=40.58205795&longitude=-111.86144257&preciseLocation=true&facet=open_now%3Atrue&sortSetId=umamiv3&sponsoredSize=3&countOmittingTimes=true&whenFor=2020-03-19T17%3A30%3A00.000Z&isFutureOrder=true",
    color: "#66596e"
  },
  {
    name: "Uber Eats",
    link: "https://www.ubereats.com/store/su-casa-mexican-restaurant/x48U_gbMSeislBSIokiUXQ",
    color: "#74bab1"
  }
];
---

<Layout
  title="Order Online"
  description="Order Su Casa Mexican Restaurant for delivery or pickup through DoorDash, GrubHub, or Uber Eats. Authentic Mexican food delivered to your door in Midvale, UT."
>
  <!-- Top colored bar -->
  <div class="top-bar"></div>

  <div class="order-content">
    <div class="container">
      <!-- Main Delivery Button -->
      <section class="main-order-section">
        <a href="https://order.spoton.com/so-su-casa-mexican-restaurant-midvale-3200/midvale-ut/600f52b924b4c47e9cc94655" target="_blank" rel="noopener noreferrer" class="main-order-btn">
          DELIVERY & PICK-UP
        </a>
      </section>

      <!-- Delivery Partners -->
      <section class="delivery-section">
        <div class="partners-grid">
          {deliveryPartners.map((partner) => (
            <a href={partner.link} target="_blank" rel="noopener noreferrer" class="partner-card" style={`--partner-color: ${partner.color}`}>
              <span class="partner-name">{partner.name}</span>
            </a>
          ))}
        </div>
      </section>

      <!-- Pickup Option -->
      <section class="pickup-section">
        <div class="pickup-content">
          <div class="pickup-text">
            <h2>Prefer to Call?</h2>
            <a href="tel:+18012551042" class="btn btn-primary">(801) 255 - 1042</a>
          </div>
          <div class="pickup-info">
            <h3>Pickup Location</h3>
            <address>
              6878 State Street<br>
              Midvale, UT 84047
            </address>
            <p class="pickup-hours">
              <strong>Hours:</strong><br>
              Mon-Thu: 11am - 8pm<br>
              Fri-Sat: 11am - 9pm<br>
              Sunday: Closed
            </p>
          </div>
        </div>
      </section>

      <!-- Catering CTA -->
      <section class="catering-cta">
        <div class="cta-content">
          <div>
            <h2>Feeding a Group?</h2>
            <p>For large orders or catering needs, contact us directly for special pricing and menu options.</p>
          </div>
          <a href="/catering" class="btn btn-primary">Catering Info</a>
        </div>
      </section>
    </div>
  </div>
</Layout>

<style>
  /* Top colored bar */
  .top-bar {
    background: #415f84;
    height: 120px;
    width: 100%;
  }

  .order-content {
    background: #f2ba65;
    padding: var(--spacing-xl) 0;
    min-height: 100vh;
  }

  /* Main Order Button */
  .main-order-section {
    text-align: center;
    padding-top: 80px;
    margin-bottom: 100vh;
  }

  .main-order-btn {
    display: inline-block;
    padding: 1.5rem 4rem;
    background: #415f84;
    color: white;
    font-size: 1.75rem;
    font-weight: 700;
    text-decoration: none;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-lg);
    transition: all var(--transition-normal);
    letter-spacing: 0.05em;
  }

  .main-order-btn:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0, 0, 0, 0.2);
  }

  /* Delivery Partners */
  .delivery-section {
    margin-bottom: var(--spacing-xl);
  }

  .partners-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: var(--spacing-md);
    max-width: 800px;
    margin: 0 auto;
  }

  .partner-card {
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: var(--spacing-md) var(--spacing-lg);
    background: white;
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    text-decoration: none;
    transition: all var(--transition-normal);
    border-bottom: 4px solid var(--partner-color);
  }

  .partner-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .partner-name {
    color: var(--color-brown-dark);
    font-weight: 600;
    font-size: 1.1rem;
  }

  /* Pickup Section */
  .pickup-section {
    background: #415f84;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    margin-bottom: var(--spacing-xl);
  }

  .pickup-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-lg);
    align-items: center;
  }

  .pickup-text h2 {
    color: white;
    margin-bottom: var(--spacing-sm);
  }

  .pickup-info {
    background: white;
    padding: var(--spacing-md);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-sm);
  }

  .pickup-info h3 {
    color: var(--color-brown-dark);
    margin: 0 0 var(--spacing-xs);
    font-size: 1.1rem;
  }

  .pickup-info address {
    font-style: normal;
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  .pickup-hours {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin: 0;
  }

  /* Catering CTA */
  .catering-cta {
    background: #415f84;
    padding: var(--spacing-md);
    border-radius: var(--radius-lg);
  }

  .catering-cta .cta-content {
    display: flex;
    align-items: center;
    gap: var(--spacing-md);
  }

  .cta-content h2 {
    color: white;
    margin: 0 0 0.25rem;
    font-size: 1.5rem;
  }

  .cta-content p {
    color: rgba(255, 255, 255, 0.9);
    margin: 0;
  }

  .catering-cta .btn {
    flex-shrink: 0;
    margin-left: auto;
  }

  .catering-cta .btn-primary {
    background: white;
    color: #415f84;
    border-color: white;
  }

  .catering-cta .btn-primary:hover {
    background: #f2ba65;
    border-color: #f2ba65;
    color: var(--color-brown-dark);
  }

  @media (max-width: 768px) {
    .main-order-btn {
      padding: 1.25rem 2.5rem;
      font-size: 1.4rem;
    }

    .pickup-content {
      grid-template-columns: 1fr;
    }

    .catering-cta .cta-content {
      flex-direction: column;
      text-align: center;
    }

    .catering-cta .btn {
      margin-left: 0;
    }
  }
</style>
