---
import Layout from '../layouts/Layout.astro';

const cateringOptions = [
  {
    title: "Taco Bar",
    description: "Build-your-own taco station with choice of proteins, fresh toppings, and salsas",
    includes: ["Choice of 2-3 proteins", "Flour & corn tortillas", "Fresh toppings bar", "Chips & salsa", "Rice & beans"]
  },
  {
    title: "Burrito Bar",
    description: "Hearty burrito station with all the fixings for a satisfying meal",
    includes: ["Choice of proteins", "Large flour tortillas", "Rice & beans", "Cheese & sour cream", "Multiple salsas"]
  },
  {
    title: "Enchilada Platter",
    description: "Classic enchiladas served family-style with all the accompaniments",
    includes: ["Choice of enchilada style", "Red & green sauces", "Mexican rice", "Refried beans", "Sour cream & guacamole"]
  },
  {
    title: "Fajita Fiesta",
    description: "Sizzling fajitas with all the trimmings for an impressive spread",
    includes: ["Chicken & steak options", "Grilled peppers & onions", "Warm tortillas", "Guacamole & sour cream", "Rice & beans"]
  },
  {
    title: "Appetizer Package",
    description: "Perfect for cocktail parties and pre-event gatherings",
    includes: ["Chips & salsa", "Guacamole", "Queso dip", "Mini quesadillas", "Loaded nachos"]
  },
  {
    title: "Custom Menu",
    description: "Work with us to create the perfect menu for your specific event",
    includes: ["Personalized consultation", "Custom menu design", "Flexible pricing", "Dietary accommodations", "Full-service options"]
  }
];
---

<Layout
  title="Catering"
  description="Bring the fiesta to your event! Su Casa Mexican Restaurant offers catering services for parties, corporate events, weddings, and more in the Midvale, UT area."
>
<div class="catering-page-wrapper">
  <!-- Banner -->
  <section class="page-banner">
    <img src="https://i.postimg.cc/cJ7LtpDq/Copy-of-queso-dip-pic-(1).jpg" alt="Su Casa Catering" class="banner-image" />
  </section>

  <div class="catering-content">
    <div class="container">
      <!-- Catering Options -->
      <section class="catering-options">
        <h2 class="section-title">Catering Packages</h2>
        <div class="options-grid">
          {cateringOptions.map((option) => (
            <div class="option-card">
              <h3>{option.title}</h3>
              <p class="option-desc">{option.description}</p>
              <ul class="option-includes">
                {option.includes.map((item) => (
                  <li>{item}</li>
                ))}
              </ul>
            </div>
          ))}
        </div>
      </section>

      <!-- Inquiry Form -->
      <section class="inquiry-section" id="inquiry-form">
        <div class="form-container">
          <div class="form-header">
            <h2>Request a Catering Quote</h2>
            <p>Fill out the form below and we'll get back to you within 24 hours</p>
          </div>
          <form class="catering-form" action="#" method="POST">
            <div class="form-row">
              <div class="form-group">
                <label for="name" class="form-label">Your Name *</label>
                <input type="text" id="name" name="name" class="form-input" required>
              </div>
              <div class="form-group">
                <label for="email" class="form-label">Email Address *</label>
                <input type="email" id="email" name="email" class="form-input" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="phone" class="form-label">Phone Number *</label>
                <input type="tel" id="phone" name="phone" class="form-input" required>
              </div>
              <div class="form-group">
                <label for="date" class="form-label">Event Date *</label>
                <input type="date" id="date" name="date" class="form-input" required>
              </div>
            </div>
            <div class="form-row">
              <div class="form-group">
                <label for="guests" class="form-label">Number of Guests *</label>
                <input type="number" id="guests" name="guests" class="form-input" min="1" required>
              </div>
              <div class="form-group">
                <label for="event-type" class="form-label">Event Type</label>
                <select id="event-type" name="event-type" class="form-select">
                  <option value="">Select event type</option>
                  <option value="birthday">Birthday Party</option>
                  <option value="corporate">Corporate Event</option>
                  <option value="wedding">Wedding/Engagement</option>
                  <option value="holiday">Holiday Party</option>
                  <option value="graduation">Graduation</option>
                  <option value="other">Other</option>
                </select>
              </div>
            </div>
            <div class="form-group">
              <label for="message" class="form-label">Additional Details</label>
              <textarea id="message" name="message" class="form-textarea" placeholder="Tell us about your event, dietary requirements, or any special requests..."></textarea>
            </div>
            <div class="form-submit">
              <button type="submit" class="btn btn-primary">Submit Inquiry</button>
              <p class="form-note">* Required fields. We'll respond within 24 hours.</p>
            </div>
          </form>
        </div>
      </section>

      <!-- Contact CTA -->
      <section class="contact-cta">
        <div class="cta-content">
          <h2>Prefer to Talk?</h2>
          <p>Give us a call to discuss your catering needs directly with our team</p>
          <a href="tel:+18012551042" class="btn btn-secondary">Call (801) 255-1042</a>
        </div>
      </section>
    </div>
  </div>
</div>
</Layout>

<style>
  /* Banner */
  .page-banner {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 350px;
    overflow: hidden;
    z-index: -1;
  }

  .catering-page-wrapper {
    padding-top: 350px;
  }

  .banner-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .catering-content {
    padding: var(--spacing-xl) 0;
  }

  /* Catering Options */
  .catering-options {
    margin-bottom: var(--spacing-xl);
  }

  .options-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: var(--spacing-md);
    margin-top: var(--spacing-lg);
  }

  .option-card {
    background: white;
    padding: var(--spacing-md);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-sm);
    transition: all var(--transition-normal);
    border-top: 4px solid var(--color-tertiary);
  }

  .option-card:hover {
    transform: translateY(-5px);
    box-shadow: var(--shadow-lg);
  }

  .option-card h3 {
    color: var(--color-brown-dark);
    margin: 0 0 var(--spacing-xs);
  }

  .option-desc {
    color: var(--color-text);
    font-size: 0.95rem;
    margin-bottom: var(--spacing-sm);
  }

  .option-includes {
    list-style: none;
    padding: 0;
    margin: 0;
    background: var(--color-cream);
    padding: var(--spacing-sm);
    border-radius: var(--radius-md);
  }

  .option-includes li {
    padding: 0.35rem 0;
    padding-left: 1.5rem;
    position: relative;
    font-size: 0.9rem;
    color: var(--color-text);
  }

  .option-includes li::before {
    content: '\2713';
    position: absolute;
    left: 0;
    color: var(--color-green);
    font-weight: bold;
  }

  /* Inquiry Form */
  .inquiry-section {
    background: white;
    padding: var(--spacing-lg);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-md);
    margin-bottom: var(--spacing-lg);
  }

  .form-header {
    text-align: center;
    margin-bottom: var(--spacing-md);
  }

  .form-header h2 {
    color: var(--color-brown-dark);
    margin-bottom: var(--spacing-xs);
  }

  .form-header p {
    color: var(--color-text-light);
    margin: 0;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--spacing-sm);
  }

  .form-submit {
    text-align: center;
    margin-top: var(--spacing-md);
  }

  .form-note {
    color: var(--color-text-light);
    font-size: 0.85rem;
    margin-top: var(--spacing-sm);
  }

  /* Contact CTA */
  .contact-cta {
    text-align: center;
    padding: var(--spacing-md);
    background: linear-gradient(135deg, var(--color-cream) 0%, #fefefe 100%);
    border-radius: var(--radius-lg);
  }

  .contact-cta h2 {
    color: var(--color-brown-dark);
    margin-bottom: var(--spacing-xs);
  }

  .contact-cta p {
    color: var(--color-text);
    margin-bottom: var(--spacing-sm);
  }

  @media (max-width: 768px) {
    .page-banner {
      height: 250px;
    }

    .catering-page-wrapper {
      padding-top: 250px;
    }

    .form-row {
      grid-template-columns: 1fr;
    }
  }
</style>
