---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Family owned since 1978, Su Casa Mexican Restaurant in Midvale, UT offers authentic Mexican cuisine in a cozy, festive atmosphere." } = Astro.props;
const fullTitle = title === 'Home' ? 'Su Casa Mexican Restaurant | Authentic Mexican Food in Midvale, UT' : `${title} | Su Casa Mexican Restaurant`;

const productionDomain = 'sucasamexicanrestaurant.com';
const canonicalURL = new URL(Astro.url.pathname, `https://${productionDomain}`);
const isProduction = Astro.url.hostname === productionDomain;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="keywords" content="Mexican restaurant, Midvale, Utah, authentic Mexican food, tacos, burritos, enchiladas, catering, family restaurant" />

    <!-- Open Graph / Social Media -->
    <meta property="og:type" content="website" />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="Su Casa Mexican Restaurant" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL.href} />
    {!isProduction && <meta name="robots" content="noindex, nofollow" />}

    <!-- Favicon -->
    <link rel="icon" type="image/png" href="/favicon/su-casa-logo.png" />
    <link rel="shortcut icon" href="/favicon/su-casa-logo.png" />
    <link rel="apple-touch-icon" href="/favicon/su-casa-logo.png" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Jost:wght@300;400;500;600;700&display=swap" rel="stylesheet" />

    <title>{fullTitle}</title>
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  h1, h2, h3, h4, h5, h6 {
    font-family: 'Jost', sans-serif;
  }
</style>
